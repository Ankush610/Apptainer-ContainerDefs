Bootstrap: docker
From: ubuntu:22.04

%labels
    Author CDAC
    Version 2.4
    Description Optimized LLM Development Environment with Python 3.11, CUDA 12.4, and comprehensive ML/NLP stack

%help
    This container provides a complete environment for AI-LLM model development.
    Includes PyTorch with CUDA support, HuggingFace Transformers, LangChain,
    and comprehensive data science libraries.

    Usage:
    apptainer shell --nv llm_development.sif
    apptainer exec --nv llm_development.sif python your_script.py
    apptainer exec --nv llm_development.sif jupyter lab --ip=0.0.0.0 --port=8888 --allow-root

%environment
    export CUDA_HOME=/usr/local/cuda
    export PATH=/usr/local/cuda/bin:$PATH
    export LD_LIBRARY_PATH=/usr/local/cuda/lib64:$LD_LIBRARY_PATH
    export PATH="/opt/conda/bin:$PATH"
    # Set conda environment variables
    export CONDA_DEFAULT_ENV=base
    export CONDA_PREFIX=/opt/conda
    export PYTHONPATH=/opt/conda/lib/python3.11/site-packages:$PYTHONPATH
    # HuggingFace cache settings
    export HF_HOME=/tmp/huggingface
    export HF_HUB_CACHE=/tmp/huggingface/hub
    export HF_DATASETS_CACHE=/tmp/huggingface/datasets
    # Other cache directories
    export WANDB_CACHE_DIR=/tmp/wandb
    export PIP_CACHE_DIR=/tmp/pip
    export TORCH_HOME=/tmp/torch
    export TOKENIZERS_PARALLELISM=false
    export MPLCONFIGDIR=/tmp/matplotlib
    # Suppress conda warnings
    export PYTHONWARNINGS="ignore::UserWarning:conda_package_streaming"

%post
    # Set non-interactive mode and suppress systemd warnings in containers
    export DEBIAN_FRONTEND=noninteractive
    export RUNLEVEL=1

    # Prevent systemd/dbus services from starting in container
    echo '#!/bin/sh\nexit 101' > /usr/sbin/policy-rc.d
    chmod +x /usr/sbin/policy-rc.d

    # Handle timezone setup
    export TZ=UTC
    ln -snf /usr/share/zoneinfo/$TZ /etc/localtime && echo $TZ > /etc/timezone

    # Install system dependencies including Python build requirements (quiet mode)
    apt-get update && apt-get install -yqq \
    build-essential \
    cmake \
    git \
    wget \
    curl \
    vim \
    nano \
    htop \
    tmux \
    screen \
    tree \
    unzip \
    zip \
    rsync \
    python3 \
    python3-dev \
    python3-pip \
    python3-venv \
    pkg-config \
    libssl-dev \
    libffi-dev \
    libbz2-dev \
    libreadline-dev \
    libsqlite3-dev \
    xz-utils \
    ca-certificates \
    sqlite3 && \
    apt-get autoremove -yqq && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

    # Download and install Miniconda
    wget https://repo.anaconda.com/miniconda/Miniconda3-latest-Linux-x86_64.sh -O /tmp/miniconda.sh
    bash /tmp/miniconda.sh -b -p /opt/conda
    rm /tmp/miniconda.sh

    # Add conda to PATH
    export PATH="/opt/conda/bin:$PATH"

    # Set conda environment variables
    export CONDA_DEFAULT_ENV=base
    export CONDA_PREFIX=/opt/conda

    # Initialize conda
    /opt/conda/bin/conda init bash

    # Update conda
    /opt/conda/bin/conda update -n base -c defaults conda -y

    # Install common packages in base environment
    /opt/conda/bin/conda install -n base -c conda-forge -c nvidia python=3.11 \
        cuda-toolkit=12.4 \
        numpy \
        pandas \
        matplotlib \
        scipy \
        scikit-learn \
        seaborn \
        plotly \
        jupyter \
        jupyterlab \
        notebook \
        ipython \
        ipykernel \
        nltk \
        requests \
        pyyaml \
        click \
        tqdm \
        joblib \
        sqlalchemy \
        pillow \
        opencv \
        ffmpeg \
        sqlite -y

    # Upgrade pip in the base environment
    /opt/conda/bin/pip install --upgrade pip setuptools wheel --root-user-action=ignore

    # Install PyTorch first with CUDA support
    /opt/conda/bin/pip install --no-cache-dir --root-user-action=ignore \
        torch torchvision torchaudio \
        --index-url https://download.pytorch.org/whl/cu121

    # Create requirements.txt with essential LLM packages
    cat > /tmp/requirements.txt << 'EOF'
# Core PyTorch ecosystem
torchtext>=0.18.0
# Transformers & HuggingFace ecosystem (Essential)
transformers>=4.36.0
huggingface-hub>=0.19.0
datasets>=2.16.0
tokenizers>=0.15.0
accelerate>=0.25.0
peft>=0.7.0
bitsandbytes>=0.42.0
sentence-transformers>=2.2.0
safetensors>=0.4.0
optimum>=1.16.0
# LangChain for LLM applications
langchain>=0.1.0
langchain-core>=0.1.0
langchain-community>=0.0.20
langchain-openai>=0.0.8
langsmith>=0.0.80
# Model serving & deployment
fastapi>=0.105.0
uvicorn[standard]>=0.25.0
gradio>=4.15.0
streamlit>=1.30.0
# Vector databases for RAG
chromadb>=0.4.20
faiss-cpu>=1.7.4
qdrant-client>=1.7.0
# API clients (most popular)
openai>=1.10.0
anthropic>=0.8.0
# Data processing
pyarrow>=15.0.0
polars>=0.20.0
# NLP utilities
spacy>=3.7.0
# MLOps & experiment tracking
wandb>=0.16.0
tensorboard>=2.15.0
mlflow>=2.9.0
# Development tools
jupyterlab-git>=0.44.0
black>=23.12.0
pytest>=7.4.0
# Configuration & utilities
python-dotenv>=1.0.0
pydantic>=2.5.0
httpx>=0.26.0
rich>=13.7.0
# Audio processing (for speech models)
librosa>=0.10.0
soundfile>=0.12.0
openai-whisper>=20231117
# Computer vision (for multimodal)
timm>=0.9.0
opencv-python>=4.8.0
# Cloud storage (deployment)
boto3>=1.34.0
# Database connections
redis>=5.0.0
psycopg2-binary>=2.9.0
EOF

    # Install all packages from requirements.txt
    /opt/conda/bin/pip install --no-cache-dir --root-user-action=ignore -r /tmp/requirements.txt

    # Setup Jupyter kernel for the base environment
    echo "Setting up Jupyter kernel..."
    /opt/conda/bin/python -m ipykernel install --user --name base --display-name "LLM Development (Python 3.11)"

    # Install spaCy models
    /opt/conda/bin/python -m spacy download en_core_web_sm
    /opt/conda/bin/python -m spacy download en_core_web_md

    # Clean up requirements file and other temporary files
    rm -f /tmp/requirements.txt

    # Final cleanup
    /opt/conda/bin/conda clean --all -y
    /opt/conda/bin/pip cache purge

    # Create cache directories with proper permissions
    mkdir -p /tmp/huggingface/hub /tmp/huggingface/datasets /tmp/matplotlib /tmp/wandb /tmp/pip /tmp/torch
    chmod -R 777 /tmp/huggingface /tmp/matplotlib /tmp/wandb /tmp/pip /tmp/torch

    echo "🎉 LLM Container Setup Completed Successfully!"
    echo "📊 Summary: Ubuntu 22.04 + Miniconda3 + Python 3.11 + CUDA 12.4"

%runscript
    # Ensure conda environment is properly set
    export PATH="/opt/conda/bin:$PATH"
    export CONDA_DEFAULT_ENV=base
    export CONDA_PREFIX=/opt/conda

    echo "=========================================="
    echo "🚀 LLM Development Container Ready!"
    echo "=========================================="
    echo ""
    echo "🔧 Environment: conda base environment (Python 3.11)"
    echo "💾 Base: Ubuntu 22.04 + Miniconda3"
    echo ""
    echo "📝 Ready to use commands:"
    echo "  • python: Python with ML/NLP libraries"
    echo "  • jupyter lab: Start Jupyter Lab"
    echo "  • pip list: See all installed packages"
    echo ""
    echo "🔗 Usage examples:"
    echo "  apptainer shell --nv llm_development.sif"
    echo "  apptainer exec --nv llm_development.sif python your_script.py"
    echo "  apptainer exec --nv llm_development.sif jupyter lab --ip=0.0.0.0"
    echo ""

    exec "$@"

%test
    # Ensure conda environment is properly set for tests
    export PATH="/opt/conda/bin:$PATH"
    export CONDA_DEFAULT_ENV=base
    export CONDA_PREFIX=/opt/conda

    echo "🧪 Running Container Tests..."

    # Test Python and basic imports
    echo "Testing Python environment..."
    /opt/conda/bin/python -c "import sys; print(f'Python {sys.version_info.major}.{sys.version_info.minor}.{sys.version_info.micro}')" || exit 1

    # Test conda environment
    echo "Testing conda environment..."
    /opt/conda/bin/conda info --envs | grep base || exit 1

    # Test CUDA
    echo "Testing CUDA availability..."
    /opt/conda/bin/python -c "
import torch
if torch.cuda.is_available():
    print(f'✅ CUDA {torch.version.cuda} with {torch.cuda.device_count()} GPU(s)')
    print(f'   Available devices: {[torch.cuda.get_device_name(i) for i in range(torch.cuda.device_count())]}')
else:
    print('⚠️  CUDA not available (expected in CPU-only environment)')
    print('   PyTorch version:', torch.__version__)
" || exit 1

    # Test core libraries
    echo "Testing core library imports..."
    /opt/conda/bin/python -c "
import transformers, langchain, pandas, numpy, matplotlib, spacy
print('✅ All core libraries imported successfully')
print(f'  - Transformers: {transformers.__version__}')
print(f'  - LangChain: {langchain.__version__}')
print(f'  - Pandas: {pandas.__version__}')
print(f'  - NumPy: {numpy.__version__}')
print(f'  - Matplotlib: {matplotlib.__version__}')
print(f'  - spaCy: {spacy.__version__}')
" || exit 1

    # Test spaCy model
    echo "Testing spaCy model..."
    /opt/conda/bin/python -c "
import spacy
nlp = spacy.load('en_core_web_sm')
doc = nlp('Test sentence for spaCy processing')
print(f'✅ spaCy model working: processed {len(doc)} tokens')
" || exit 1

    # Test PyTorch tensor operations
    echo "Testing PyTorch operations..."
    /opt/conda/bin/python -c "
import torch
x = torch.randn(3, 3)
result = torch.matmul(x, x)
print('✅ PyTorch tensor operations working')
print(f'   Input shape: {x.shape}, Output shape: {result.shape}')
if torch.cuda.is_available():
    x_gpu = x.cuda()
    result_gpu = torch.matmul(x_gpu, x_gpu)
    print('✅ CUDA operations working')
" || exit 1

    # Test HuggingFace functionality
    echo "Testing HuggingFace transformers..."
    /opt/conda/bin/python -c "
from transformers import AutoTokenizer
tokenizer = AutoTokenizer.from_pretrained('distilbert-base-uncased')
tokens = tokenizer('Hello world, this is a test')
print('✅ HuggingFace tokenizer working')
print(f'   Tokenized length: {len(tokens[\"input_ids\"])}')
" || exit 1

    echo ""
    echo "🎉 All tests passed! Container is ready for LLM development."
    echo ""
    echo "📊 Container Summary:"
    echo "  - Base: Ubuntu 22.04 + Miniconda3"
    echo "  - Environment: Base conda environment"
    echo "  - Python: 3.11"
    echo "  - CUDA: 12.4 toolkit"
    echo "  - PyTorch: Latest compatible with CUDA support"
    echo "  - Ready for: LLM development, fine-tuning, RAG applications"
