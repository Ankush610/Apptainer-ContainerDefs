<<<<<How to Run>>>>>

  ================================================================================
    QUICK START
  ================================================================================
    apptainer run --nv container.sif

  (--nv gives access to the GPU. Drop it only on a CPU-only host.)


  ================================================================================
    MODES & FLAGS
  ================================================================================
    MODES
    --------------------------------------------------------------------------
      jupyter (default)      JupyterLab
        apptainer run --nv --bind /my/code:/code container.sif jupyter

      tensorboard            TensorBoard, pointed at /output
        apptainer run --nv --bind /my/output:/output container.sif tensorboard

      jupyter+tensorboard    Both at once
        apptainer run --nv --bind /my/code:/code --bind /my/output:/output \
          container.sif jupyter+tensorboard

    FLAGS
    --------------------------------------------------------------------------
      --nv                --nv        (NVIDIA GPUs)
      --rocm              --rocm      (AMD GPUs, instead of --nv)
      --bind src:dst      --bind /my/code:/code --bind /my/data:/data --bind /my/output:/output
      --env KEY=VALUE     --env CUDA_VISIBLE_DEVICES=0

    Directories to bind: /code /data /output /model (HF_HOME=/model/hf-cache) /scratch


  ================================================================================
    RUN YOUR OWN SCRIPT (EXEC)
  ================================================================================
    # Single GPU / CPU
    apptainer exec --nv \
      --bind /my/code:/code --bind /my/data:/data --bind /my/output:/output \
      container.sif python /code/train.py

    # Multiple GPUs on one node (torchrun)
    apptainer exec --nv \
      --bind /my/code:/code --bind /my/data:/data --bind /my/output:/output \
      container.sif torchrun --nproc_per_node=4 /code/train.py


  ================================================================================
    SLURM — SINGLE NODE
  ================================================================================
    #!/bin/bash
    #SBATCH --job-name=torch-train
    #SBATCH --gres=gpu:2
    #SBATCH --cpus-per-task=16
    #SBATCH --partition=gpu
    #SBATCH --output=./logs/logs_%j.out
    #SBATCH --error=./logs/logs_%j.err
    #SBATCH --time=04:00:00

    echo "===================================="
    echo "Job Name   : $SLURM_JOB_NAME"
    echo "GPUs       : $SLURM_GPUS_ON_NODE"
    echo "===================================="

    srun apptainer exec --nv \
      --bind /my/code:/code --bind /my/data:/data --bind /my/output:/output \
      --bind /my/model:/model \
      container.sif torchrun --nproc_per_node=2 /code/train.py

    echo "===================================="
    echo "Training Completed"
    echo "===================================="


  ================================================================================
    SLURM — MULTI-NODE  (adapted from /example-script.sh at the project root —
                         same torchrun/rdzv shape, wrapped in apptainer exec)
  ================================================================================
    #!/bin/bash
    #SBATCH --job-name=cifar10_ddp
    #SBATCH --nodes=2
    #SBATCH --ntasks-per-node=1
    #SBATCH --gres=gpu:2
    #SBATCH --cpus-per-task=16
    #SBATCH --partition=gpu
    #SBATCH --output=./logs/logs_%j.out
    #SBATCH --error=./logs/logs_%j.err
    #SBATCH --time=02:00:00

    export MASTER_ADDR=$(scontrol show hostnames $SLURM_JOB_NODELIST | head -n 1)
    export MASTER_PORT=29500
    export GPUS_PER_NODE=$(echo $CUDA_VISIBLE_DEVICES | tr ',' '\n' | wc -l)
    export WORLD_SIZE=$((SLURM_NNODES * GPUS_PER_NODE))

    export NCCL_DEBUG=WARN
    export NCCL_IB_DISABLE=0
    export NCCL_P2P_DISABLE=0

    echo "===================================="
    echo "Job Name   : $SLURM_JOB_NAME"
    echo "Master Addr: $MASTER_ADDR"
    echo "Nodes      : $SLURM_NNODES"
    echo "GPUs/Node  : $GPUS_PER_NODE"
    echo "World Size : $WORLD_SIZE"
    echo "===================================="

    # No conda-pre-req.sh needed here — the container IS the environment.
    srun apptainer exec --nv \
      --bind /my/code:/code --bind /my/data:/data --bind /my/output:/output \
      container.sif \
      torchrun \
        --nnodes=$SLURM_NNODES \
        --nproc-per-node=$GPUS_PER_NODE \
        --rdzv-id=$SLURM_JOB_ID \
        --rdzv-backend=c10d \
        --rdzv-endpoint=$MASTER_ADDR:$MASTER_PORT \
        /code/mnist-train-ddp.py \
        --epochs=10 \
        --batch-size=32

    echo "===================================="
    echo "Training Completed"
    echo "===================================="

    On Ethernet-only nodes add: --env NCCL_IB_DISABLE=1 --env NCCL_SOCKET_IFNAME=eth0
    (InfiniBand nodes need nothing extra — NCCL auto-detects.)


  ================================================================================
    CHECKING IT WORKS
  ================================================================================
    apptainer test --nv container.sif

