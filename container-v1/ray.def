Bootstrap: docker
From: pytorch/pytorch:2.7.0-cuda12.8-cudnn9-runtime

%labels
    Maintainer       Ankush / CDAC Pune
    Org              CDAC
    Version          1.0.0
    Framework        Ray 2.53.0 + PyTorch 2.7.0
    CUDA_Version     12.8
    CUDA_Driver_Min  525.60
    CUDA_Range       525.60 – tested
    cuDNN_Version    9
    Python_Version   3.11
    CPU_Capable      yes
    Description      Ray Train + Ray Tune distributed training on SLURM. Does NOT include Ray Serve or RLlib.
    Modes            train,dist,tune,jupyter,info,bash,help

%setup
    mkdir -p ${SINGULARITY_ROOTFS}/etc/apt/apt.conf.d
    echo 'APT::Sandbox::User "root";' \
      > ${SINGULARITY_ROOTFS}/etc/apt/apt.conf.d/99sandbox-fix

    mkdir -p ${SINGULARITY_ROOTFS}/code
    mkdir -p ${SINGULARITY_ROOTFS}/data
    mkdir -p ${SINGULARITY_ROOTFS}/output
    mkdir -p ${SINGULARITY_ROOTFS}/model
    mkdir -p ${SINGULARITY_ROOTFS}/scratch

%post
    [ -z "$BASH" ] && exec /bin/bash "$0" "$@"
    set -euo pipefail

    DEBIAN_FRONTEND=noninteractive apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        wget curl git unzip zip ca-certificates \
        ffmpeg libgl1-mesa-glx libgl1 \
        libglib2.0-0 libsm6 libxrender1 libxext6 \
        libgomp1 build-essential vim \
        libibverbs1 librdmacm1 ibverbs-utils

    pip install --no-cache-dir --upgrade pip setuptools wheel

    # numpy first, alone
    pip install --no-cache-dir \
        "numpy==1.26.4"

    # PyTorch stack already in base image — install Ray + ML ecosystem on top
    # Transitive deps (pydantic, fsspec, pyarrow, aiohttp, click, rich,
    # requests, tokenizers, filelock) intentionally unpinned — Ray's resolver
    # owns them and pins specific minor versions we must not override.
    pip install --no-cache-dir \
        "ray[train,tune,data]==2.53.0" \
        "torchvision==0.22.0" \
        "torchaudio==2.7.0" \
        "transformers==4.47.1" \
        "accelerate==1.2.1" \
        "datasets==3.2.0" \
        "safetensors==0.4.5" \
        "optuna==4.1.0" \
        "tensorboard==2.18.0" \
        "tensorboardX==2.6.2.2" \
        "mlflow==2.19.0" \
        "scikit-learn==1.6.0" \
        "scipy==1.14.1" \
        "pandas==2.2.3" \
        "tqdm==4.67.1" \
        "PyYAML==6.0.2"

    pip install --no-cache-dir \
        "jupyterlab==4.3.4"

    mkdir -p /etc/pip
    pip freeze > /etc/pip/constraint.txt

    # Write entrypoint
    cat > /opt/entrypoint.sh << 'ENTRYEOF'
#!/bin/bash
set -euo pipefail

MODE="${1:-help}"
shift 2>/dev/null || true

GPU_COUNT=$(nvidia-smi --query-gpu=name --format=csv,noheader 2>/dev/null | wc -l || echo 0)

_info() { python3 - <<'EOF'
import sys, torch, ray
print(f"Python:     {sys.version.split()[0]}")
print(f"PyTorch:    {torch.__version__}  CUDA: {torch.version.cuda}  cuDNN: {torch.backends.cudnn.version()}")
print(f"Ray:        {ray.__version__}")
if torch.cuda.is_available():
    for i in range(torch.cuda.device_count()):
        p = torch.cuda.get_device_properties(i)
        print(f"  GPU {i}: {p.name} — {p.total_memory//1024**2} MB")
else:
    print("No GPU — CPU mode active")
try:
    import transformers, accelerate, optuna, sklearn
    print(f"Transformers: {transformers.__version__}  Accelerate: {accelerate.__version__}")
    print(f"Optuna:       {optuna.__version__}  scikit-learn: {sklearn.__version__}")
except Exception as e:
    print(f"[WARNING] partial import: {e}")
EOF
}

case "$MODE" in
    train)
        SCRIPT=""
        EXTRA_ARGS=()
        while [[ $# -gt 0 ]]; do
            case "$1" in
                --script) SCRIPT="$2"; shift 2 ;;
                --) shift; EXTRA_ARGS=("$@"); break ;;
                *) EXTRA_ARGS+=("$1"); shift ;;
            esac
        done
        [[ -z "$SCRIPT" ]] && { echo "ERROR: --script PATH required"; exit 1; }
        [[ "$GPU_COUNT" -eq 0 ]] && echo "[WARNING] No GPU detected — CPU mode"
        exec python3 "$SCRIPT" "${EXTRA_ARGS[@]}"
        ;;
    dist)
        SCRIPT=""
        NPROC="${GPU_COUNT:-1}"
        PORT=6379
        EXTRA_ARGS=()
        while [[ $# -gt 0 ]]; do
            case "$1" in
                --script)       SCRIPT="$2";  shift 2 ;;
                --nproc)        NPROC="$2";   shift 2 ;;
                --master-port)  PORT="$2";    shift 2 ;;
                --) shift; EXTRA_ARGS=("$@"); break ;;
                *) EXTRA_ARGS+=("$1"); shift ;;
            esac
        done
        [[ -z "$SCRIPT" ]] && { echo "ERROR: --script PATH required"; exit 1; }
        [[ "$GPU_COUNT" -eq 0 ]] && echo "[WARNING] No GPU detected — CPU mode"
        exec torchrun \
            --nproc_per_node="$NPROC" \
            --master_port="$PORT" \
            "$SCRIPT" "${EXTRA_ARGS[@]}"
        ;;
    tune)
        SCRIPT=""
        EXTRA_ARGS=()
        while [[ $# -gt 0 ]]; do
            case "$1" in
                --script) SCRIPT="$2"; shift 2 ;;
                --) shift; EXTRA_ARGS=("$@"); break ;;
                *) EXTRA_ARGS+=("$1"); shift ;;
            esac
        done
        [[ -z "$SCRIPT" ]] && { echo "ERROR: --script PATH required"; exit 1; }
        [[ "$GPU_COUNT" -eq 0 ]] && echo "[WARNING] No GPU detected — CPU mode"
        exec python3 "$SCRIPT" "${EXTRA_ARGS[@]}"
        ;;
    jupyter)
        PORT=8888
        while [[ $# -gt 0 ]]; do
            case "$1" in
                --port) PORT="$2"; shift 2 ;;
                *) shift ;;
            esac
        done
        echo "JupyterLab starting on port $PORT — SSH tunnel required"
        exec jupyter lab \
            --no-browser \
            --ip=0.0.0.0 \
            --port="$PORT" \
            --notebook-dir=/code \
            --ServerApp.token='' \
            --ServerApp.password=''
        ;;
    info)  _info ;;
    bash)  exec /bin/bash ;;
    help|-h|--help)
        cat << 'HELPEOF'
Usage: apptainer exec --nv <container>.sif [MODE] [ARGS...]
  train   --script PATH [-- ARGS]
  dist    --script PATH [--nproc N] [--master-port N] [-- ARGS]
  tune    --script PATH [-- ARGS]
  jupyter [--port N]
  info / bash / <cmd>
Run: apptainer run-help <container>.sif  for full docs.
HELPEOF
        ;;
    *)  exec "$MODE" "$@" ;;
esac
ENTRYEOF
    chmod +x /opt/entrypoint.sh

    # Smoke test
    python3 -c "
import sys
print('Python:', sys.version)

def ver(mod, attr='__version__'):
    try:
        v = getattr(mod, attr, None)
        if v is None:
            import importlib.metadata
            v = importlib.metadata.version(mod.__name__)
        return str(v)
    except Exception:
        return '(version unknown)'

def safe_import(name, attr=None):
    try:
        import importlib
        mod = importlib.import_module(name)
        version = ver(mod, attr) if attr else ver(mod)
        return mod, version
    except ImportError:
        print(f'[WARNING] MISSING package: {name} — not found in container')
        return None, 'MISSING'

packages = [
    ('torch',          None,      'PyTorch      '),
    ('ray',            None,      'Ray          '),
    ('torchvision',    None,      'torchvision  '),
    ('torchaudio',     None,      'torchaudio   '),
    ('transformers',   None,      'transformers '),
    ('accelerate',     None,      'accelerate   '),
    ('datasets',       None,      'datasets     '),
    ('optuna',         None,      'optuna       '),
    ('tensorboard',    None,      'tensorboard  '),
    ('mlflow',         None,      'mlflow       '),
    ('sklearn',        None,      'scikit-learn '),
    ('scipy',          None,      'scipy        '),
    ('pandas',         None,      'pandas       '),
    ('numpy',          None,      'numpy        '),
    ('pyarrow',        None,      'pyarrow      '),
    ('yaml',           None,      'PyYAML       '),
    ('pydantic',       None,      'pydantic     '),
    ('tqdm',           None,      'tqdm         '),
    ('rich',           None,      'rich         '),
    ('jupyterlab',     None,      'jupyterlab   '),
]

missing = []
for mod_name, attr, label in packages:
    _, version = safe_import(mod_name, attr) if attr else safe_import(mod_name)
    status = version if version != 'MISSING' else 'MISSING <- CHECK MANUALLY'
    print(f'{label}: {status}')
    if version == 'MISSING':
        missing.append(mod_name)

try:
    import subprocess
    r = subprocess.run(['nvidia-smi', '--query-gpu=name,memory.total',
                        '--format=csv,noheader'], capture_output=True, text=True)
    if r.returncode == 0 and r.stdout.strip():
        for i, line in enumerate(r.stdout.strip().split('\n')):
            print(f'  GPU {i}: {line}')
    else:
        print('nvidia-smi: no GPU visible in build env — OK')
except FileNotFoundError:
    print('nvidia-smi not found in build env — GPU check skipped (expected)')

if missing:
    print()
    print('BUILD WARNING: the following packages were not found:')
    for m in missing:
        print(f'  - {m}')
    print('Build continues. Verify manually: apptainer exec <container>.sif info')
else:
    print('ALL IMPORTS OK')
"

    apt-get clean && rm -rf /var/lib/apt/lists/*
    ldconfig
    find /usr/local/cuda/lib64 -name 'libcuda*.so*' 2>/dev/null | head -5 || true
    find /usr/local/cuda/lib64 -name 'libcudnn*.so*' 2>/dev/null | head -3 || true

%environment
    export PATH=/usr/local/bin:$PATH
    export PYTHONDONTWRITEBYTECODE=1
    export PYTHONUNBUFFERED=1
    export PIP_CONSTRAINT=/etc/pip/constraint.txt
    export HF_HUB_DISABLE_TELEMETRY=1
    export OMP_NUM_THREADS=${SLURM_CPUS_PER_TASK:-4}
    export MPLBACKEND=Agg
    export NCCL_DEBUG=WARN
    export NCCL_IB_DISABLE=0
    export ACCELERATE_DISABLE_RICH=1
    export RAY_TMPDIR=/tmp/ray
    export TUNE_RESULT_DIR=/output/ray_results
    export RAY_DEDUP_LOGS=1

%startscript
    [ -z "$BASH" ] && exec /bin/bash "$0" "$@"
    mkdir -p /tmp/ray /tmp/torch_cache /tmp/hf_cache
    export TORCH_HOME=/tmp/torch_cache
    export HF_HOME=/tmp/hf_cache
    exec /opt/entrypoint.sh "$@"

%runscript
    [ -z "$BASH" ] && exec /bin/bash "$0" "$@"
    if [ $# -eq 0 ]; then
        /opt/entrypoint.sh help
        exec /bin/bash
    else
        exec /opt/entrypoint.sh "$@"
    fi

%help
================================================================================
  RAY TRAIN + TUNE  v1.0.0
  Ray 2.53.0 + PyTorch 2.7.0 + CUDA 12.8 — distributed training and
  hyperparameter tuning via Ray Train and Ray Tune on SLURM.
  Does NOT include Ray Serve or RLlib.
================================================================================

BUILD
  sudo apptainer build <container>.sif <def>.def
  apptainer build --fakeroot <container>.sif <def>.def

--------------------------------------------------------------------------------
BIND POINTS
--------------------------------------------------------------------------------
  /code    Project source code    $HOME/code   (e.g. /home/username/code)
  /data    Input datasets         $HOME/data
  /output  Checkpoints, results   $HOME/output
  /model   Pretrained weights     $HOME/model
  /scratch Node-local temp        $TMPDIR or /tmp/scratch

  $HOME and /tmp auto-mounted by Apptainer.

  Example bind flag:
    --bind $HOME/code:/code,$HOME/data:/data,$HOME/output:/output,$HOME/model:/model

--------------------------------------------------------------------------------
APPTAINER FLAGS
--------------------------------------------------------------------------------
  --nv                Pass NVIDIA GPU(s) into container
  --bind src:dst      Mount host path at container path
  --env KEY=VALUE     Set env var inside container
  --writable-tmpfs    Writable overlay on read-only .sif
  --no-home           Do not auto-mount $HOME
  --cleanenv          Clear host environment before entering

  exec → run specific command   run → invoke %runscript   shell → interactive

--------------------------------------------------------------------------------
ENTRYPOINT MODES
--------------------------------------------------------------------------------
  train   Single-GPU or CPU training via python3
    apptainer exec --nv --bind $HOME/code:/code <container>.sif \
      train --script /code/train.py -- --epochs 10

  dist    Multi-GPU/multi-node via torchrun (for Ray TorchTrainer DDP scripts)
    apptainer exec --nv --bind $HOME/code:/code <container>.sif \
      dist --script /code/train_dist.py --nproc 4 --master-port 29500

  tune    Ray Tune hyperparameter search (single-node or multi-node via Ray cluster)
    apptainer exec --nv --bind $HOME/code:/code <container>.sif \
      tune --script /code/tune_job.py -- --num-samples 20

  jupyter Start headless JupyterLab (SSH port-forward required)
    apptainer exec --nv --bind $HOME/code:/code <container>.sif jupyter --port 8888

  info    Print framework versions and GPU inventory
    apptainer exec --nv <container>.sif info

  bash    Interactive shell
    apptainer shell --nv <container>.sif

  <cmd>   Passthrough — any other command is exec'd directly

--------------------------------------------------------------------------------
SLURM INTEGRATION
--------------------------------------------------------------------------------
  Single-node GPU (train mode):
    #!/bin/bash
    #SBATCH --nodes=1
    #SBATCH --ntasks=1
    #SBATCH --gres=gpu:4
    #SBATCH --cpus-per-task=16
    apptainer exec --nv \
      --bind $HOME/code:/code,$HOME/data:/data,$HOME/output:/output \
      <container>.sif train --script /code/train.py

  Multi-node Ray Train (torchrun DDP):
    #!/bin/bash
    #SBATCH --nodes=2
    #SBATCH --ntasks-per-node=1
    #SBATCH --gres=gpu:4
    #SBATCH --cpus-per-task=16
    MASTER=$(scontrol show hostnames "$SLURM_JOB_NODELIST" | head -1)
    srun apptainer exec --nv \
      --bind $HOME/code:/code,$HOME/data:/data,$HOME/output:/output \
      <container>.sif dist --script /code/train_dist.py \
        --nproc 4 --master-port 29500

  CPU-only (tune / preprocessing):
    #!/bin/bash
    #SBATCH --nodes=1
    #SBATCH --ntasks=1
    #SBATCH --cpus-per-task=8
    apptainer exec \
      --bind $HOME/code:/code,$HOME/data:/data,$HOME/output:/output \
      <container>.sif tune --script /code/tune_job.py

--------------------------------------------------------------------------------
RAY CLUSTER ON SLURM
--------------------------------------------------------------------------------
  For multi-node Ray Tune / Ray Train jobs, start a Ray cluster via srun:

  Head node (rank 0):
    ray start --head --port=6380 --num-gpus=$SLURM_GPUS_ON_NODE

  Worker nodes:
    ray start --address=$HEAD_NODE_IP:6380 --num-gpus=$SLURM_GPUS_ON_NODE

  In your script:
    import ray
    ray.init(address="auto")

  Or use the Ray SLURM cluster launcher (ray up) with a cluster YAML config.

--------------------------------------------------------------------------------
TWO-PHASE WORKFLOW
--------------------------------------------------------------------------------
  Phase 1 (login node): download data/weights/code → $HOME
  Phase 2 (compute node): bind $HOME paths, no network calls

--------------------------------------------------------------------------------
JUPYTERLAB SSH TUNNEL
--------------------------------------------------------------------------------
  1. Submit job: apptainer exec --nv <container>.sif jupyter --port 8888
  2. On local machine: ssh -L 8888:compute-node:8888 login-node
  3. Open browser: http://localhost:8888

--------------------------------------------------------------------------------
USER VENV WORKFLOW
--------------------------------------------------------------------------------
  apptainer exec <container>.sif bash
  python3 -m venv --system-site-packages $HOME/envs/myenv
  source $HOME/envs/myenv/bin/activate
  unset PIP_CONSTRAINT    # required — releases base env lock
  pip install <extra-packages>

  venvs live in $HOME/envs (home-backed), survive container updates.

--------------------------------------------------------------------------------
CUDA DRIVER COMPATIBILITY
--------------------------------------------------------------------------------
  Container CUDA   Min host driver   Tested range
  12.8             525.60            525.60 – current
  Check: nvidia-smi

--------------------------------------------------------------------------------
CPU FALLBACK
--------------------------------------------------------------------------------
  Run without --nv / --gres=gpu. Warning printed: "No GPU detected — CPU mode".
  Test: CUDA_VISIBLE_DEVICES="" apptainer exec <container>.sif info

--------------------------------------------------------------------------------
INSTALLED PACKAGES
--------------------------------------------------------------------------------
  [Fill with actual pinned versions at build time — run: apptainer exec <container>.sif info]
  Ray             2.53.0
  PyTorch         2.7.0
  torchvision     0.22.0
  torchaudio      2.7.0
  transformers    4.47.1
  accelerate      1.2.1
  datasets        3.2.0
  safetensors     0.4.5
  optuna          4.1.0
  tensorboard     2.18.0
  tensorboardX    2.6.2.2
  mlflow          2.19.0
  scikit-learn    1.6.0
  scipy           1.14.1
  pandas          2.2.3
  numpy           1.26.4
  JupyterLab      4.3.4
  tokenizers      (resolved by transformers)
  pyarrow         (resolved by ray[data])
  pydantic        (resolved by ray[tune], 2.12+)
  fsspec          (resolved by datasets, <=2024.9.0)
  CUDA            12.8
  cuDNN           9
  Python          3.11
================================================================================

