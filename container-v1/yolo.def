Bootstrap: docker
From: pytorch/pytorch:2.2.0-cuda12.1-cudnn8-runtime

%labels
    Maintainer        CDAC
    Version           7.0.0
    Framework         PyTorch+Ultralytics
    CUDA_Version      12.1
    CUDA_Driver_Min   525.60
    CUDA_Range        12.1–12.4+
    cuDNN_Version     8
    Python_Version    3.11
    CPU_Capable       YES
    Description       Apptainer container for YOLO11 object-detection training. \
                      Ships YOLOv11 weights (all 5 sizes) baked in. \
                      Pinned deps for PyTorch 2.2 / CUDA 12.1. \
                      Does NOT include roboflow (incompatible with headless cv2).
    Modes             train dist jupyter info bash

# ─────────────────────────────────────────────────────────────────────────────
# SETUP  (runs on HOST before %post — uses ${SINGULARITY_ROOTFS})
# ─────────────────────────────────────────────────────────────────────────────
%setup
    mkdir -p ${SINGULARITY_ROOTFS}/etc/apt/apt.conf.d
    echo 'APT::Sandbox::User "root";' \
      > ${SINGULARITY_ROOTFS}/etc/apt/apt.conf.d/99sandbox-fix

    mkdir -p ${SINGULARITY_ROOTFS}/data
    mkdir -p ${SINGULARITY_ROOTFS}/output
    mkdir -p ${SINGULARITY_ROOTFS}/model
    mkdir -p ${SINGULARITY_ROOTFS}/code
    mkdir -p ${SINGULARITY_ROOTFS}/scratch

# ─────────────────────────────────────────────────────────────────────────────
# POST
# ─────────────────────────────────────────────────────────────────────────────
%post
    [ -z "$BASH" ] && exec /bin/bash "$0" "$@"
    set -euo pipefail
    export DEBIAN_FRONTEND=noninteractive

    apt-get update -qq && apt-get install -y --no-install-recommends \
        wget curl git unzip zip ca-certificates \
        ffmpeg libgl1-mesa-glx libgl1 \
        libglib2.0-0 libsm6 libxrender1 libxext6 \
        libgomp1 build-essential vim \
        libibverbs1 librdmacm1 ibverbs-utils && \
    apt-get clean && rm -rf /var/lib/apt/lists/*

    ldconfig
    ldconfig -p | grep libGL || { echo "[ERROR] libGL.so.1 not found — aborting."; exit 1; }

    pip install --no-cache-dir "pip==24.0" "setuptools==69.5.1" "wheel==0.43.0"

    pip install --no-cache-dir "numpy==1.26.4"

    pip install --no-cache-dir \
        "opencv-python-headless==4.9.0.80" \
        "ultralytics==8.3.40" \
        "PyYAML==6.0.1" \
        "Pillow==10.3.0" \
        "matplotlib==3.8.4" \
        "seaborn==0.13.2" \
        "pandas==2.2.2" \
        "scipy==1.13.1" \
        "tensorboard==2.16.2" \
        "tqdm==4.66.4" \
        "psutil==5.9.8" \
        "py-cpuinfo==9.0.0" \
        "jupyterlab==4.2.5"

    python3 -c "
import sys
print('Python:', sys.version)

def ver(mod, attr='__version__'):
    try:
        v = getattr(mod, attr, None)
        if v is None:
            import importlib.metadata
            v = importlib.metadata.version(mod.__name__)
        return str(v)
    except Exception:
        return '(version unknown)'

def safe_import(name, attr=None):
    try:
        import importlib
        mod = importlib.import_module(name)
        version = ver(mod, attr) if attr else ver(mod)
        return mod, version
    except ImportError:
        print(f'[WARNING] MISSING package: {name} — not found in container')
        return None, 'MISSING'

packages = [
    ('torch',           None,      'PyTorch            '),
    ('ultralytics',     None,      'ultralytics         '),
    ('cv2',             None,      'opencv-headless     '),
    ('numpy',           None,      'NumPy               '),
    ('PIL',             'VERSION', 'Pillow              '),
    ('yaml',            None,      'PyYAML              '),
    ('matplotlib',      None,      'matplotlib          '),
    ('pandas',          None,      'pandas              '),
    ('scipy',           None,      'scipy               '),
    ('tensorboard',     None,      'tensorboard         '),
    ('tqdm',            None,      'tqdm                '),
    ('psutil',          None,      'psutil              '),
    ('cpuinfo',         None,      'py-cpuinfo          '),
    ('jupyterlab',      None,      'jupyterlab          '),
]

missing = []
for mod_name, attr, label in packages:
    _, version = safe_import(mod_name, attr) if attr else safe_import(mod_name)
    status = version if version != 'MISSING' else 'MISSING <- CHECK MANUALLY'
    print(f'{label}: {status}')
    if version == 'MISSING':
        missing.append(mod_name)

try:
    import subprocess
    r = subprocess.run(['nvidia-smi', '--query-gpu=name,memory.total',
                        '--format=csv,noheader'], capture_output=True, text=True)
    if r.returncode == 0 and r.stdout.strip():
        for i, line in enumerate(r.stdout.strip().split('\n')):
            print(f'  GPU {i}: {line}')
    else:
        print('nvidia-smi: no GPU visible in build env — OK')
except FileNotFoundError:
    print('nvidia-smi not found in build env — GPU check skipped (expected)')

if missing:
    print()
    print('BUILD WARNING: the following packages were not found:')
    for m in missing: print(f'  - {m}')
    print('Verify manually: apptainer exec <container>.sif info')
else:
    print('ALL IMPORTS OK')
"

    mkdir -p /opt/yolo_weights
    WEIGHTS_URL="https://github.com/ultralytics/assets/releases/download/v8.3.0"
    for SIZE in n s m l x; do
        echo "[BUILD] Downloading yolo11${SIZE}.pt ..."
        wget -q --show-progress \
            -O "/opt/yolo_weights/yolo11${SIZE}.pt" \
            "${WEIGHTS_URL}/yolo11${SIZE}.pt"
    done
    echo "[BUILD] Weights inventory:"
    ls -lh /opt/yolo_weights/

    mkdir -p /etc/pip
    pip freeze > /etc/pip/constraint.txt

    cat > /opt/entrypoint.sh << 'ENTRYPOINT_SCRIPT'
#!/bin/bash
[ -z "$BASH" ] && exec /bin/bash "$0" "$@"
set -euo pipefail

MODE="${1:-help}"
shift 2>/dev/null || true

GPU_COUNT=$(nvidia-smi --query-gpu=name --format=csv,noheader 2>/dev/null | wc -l || echo 0)

_info() {
python3 - <<'EOF'
import sys, torch
print(f"Python:  {sys.version.split()[0]}")
print(f"PyTorch: {torch.__version__}  CUDA: {torch.version.cuda}  cuDNN: {torch.backends.cudnn.version()}")
if torch.cuda.is_available():
    for i in range(torch.cuda.device_count()):
        p = torch.cuda.get_device_properties(i)
        print(f"  GPU {i}: {p.name} — {p.total_memory//1024**2} MB")
else:
    print("No GPU — CPU mode active")

import ultralytics, cv2, numpy, PIL, jupyterlab
print(f"ultralytics: {ultralytics.__version__}")
print(f"opencv:      {cv2.__version__}")
print(f"numpy:       {numpy.__version__}")
print(f"Pillow:      {PIL.VERSION}")
print(f"jupyterlab:  {jupyterlab.__version__}")
EOF
}

WEIGHTS_DIR="/opt/yolo_weights"
CUSTOM_WEIGHT="${WEIGHTS_DIR}/custom.pt"

case "$MODE" in
    train)
        SCRIPT=""
        YOLO_SIZE="n"
        DATA_PATH=""
        CLASSES=""
        OUTPUT_DIR="/output"
        EPOCHS=100
        BATCH=16
        IMG_SIZE=640
        WORKERS=8
        LR0=0.01
        LRF=0.01
        MOMENTUM=0.937
        WEIGHT_DECAY=0.0005
        PATIENCE=50
        DEVICE="0"
        PROJECT_NAME="yolo_train"
        RUN_NAME="exp"
        RESUME=false
        EXTRA_ARGS=""
        while [[ $# -gt 0 ]]; do
            case "$1" in
                --variant)       YOLO_SIZE="$2";      shift 2 ;;
                --data)          DATA_PATH="$2";      shift 2 ;;
                --classes)       CLASSES="$2";        shift 2 ;;
                --output)        OUTPUT_DIR="$2";     shift 2 ;;
                --epochs)        EPOCHS="$2";         shift 2 ;;
                --batch)         BATCH="$2";          shift 2 ;;
                --img-size)      IMG_SIZE="$2";       shift 2 ;;
                --workers)       WORKERS="$2";        shift 2 ;;
                --lr0)           LR0="$2";            shift 2 ;;
                --lrf)           LRF="$2";            shift 2 ;;
                --momentum)      MOMENTUM="$2";       shift 2 ;;
                --weight-decay)  WEIGHT_DECAY="$2";   shift 2 ;;
                --patience)      PATIENCE="$2";       shift 2 ;;
                --device)        DEVICE="$2";         shift 2 ;;
                --project)       PROJECT_NAME="$2";   shift 2 ;;
                --run)           RUN_NAME="$2";       shift 2 ;;
                --extra)         EXTRA_ARGS="$2";     shift 2 ;;
                --resume)        RESUME=true;         shift   ;;
                -h|--help)       exec /opt/entrypoint.sh help ;;
                --) shift; break ;;
                *) echo "[ERROR] Unknown flag: $1"; exec /opt/entrypoint.sh help ;;
            esac
        done
        [[ -z "$DATA_PATH" ]] && { echo "[ERROR] --data is required."; exec /opt/entrypoint.sh help; }
        [[ "$GPU_COUNT" -eq 0 ]] && echo "[WARN] No GPU — CPU mode"
        mkdir -p "$OUTPUT_DIR"

        if [[ -f "$CUSTOM_WEIGHT" ]]; then
            MODEL_ARG="$CUSTOM_WEIGHT"
            echo "[INFO] Custom weight detected: ${MODEL_ARG}"
        else
            SIZE=$(echo "$YOLO_SIZE" | tr '[:upper:]' '[:lower:]')
            SIZE="${SIZE##yolo11}"; SIZE="${SIZE##yolov11}"
            case "$SIZE" in
                n|s|m|l|x) ;;
                *) echo "[ERROR] --variant '${YOLO_SIZE}' invalid. Use: n s m l x"; exit 1 ;;
            esac
            MODEL_ARG="${WEIGHTS_DIR}/yolo11${SIZE}.pt"
            echo "[INFO] Using built-in YOLOv11${SIZE}: ${MODEL_ARG}"
        fi

        if [[ "$DATA_PATH" == *.yaml || "$DATA_PATH" == *.yml ]]; then
            DATASET_YAML="$DATA_PATH"
        else
            [[ -z "$CLASSES" ]] && { echo "[ERROR] --classes required for directory dataset."; exit 1; }
            DATASET_YAML="$OUTPUT_DIR/dataset.yaml"
            IFS=',' read -ra CLASS_ARRAY <<< "$CLASSES"
            NC=${#CLASS_ARRAY[@]}
            NAMES_LIST=$(python3 -c "
import sys
classes = sys.argv[1].split(',')
print('[' + ', '.join(repr(c.strip()) for c in classes) + ']')
" "$CLASSES")
            cat > "$DATASET_YAML" << YAML
path: ${DATA_PATH}
train: images/train
val:   images/val
nc: ${NC}
names: ${NAMES_LIST}
YAML
        fi

        RESUME_FLAG=""
        $RESUME && RESUME_FLAG="resume=True"

        exec yolo detect train \
            model="$MODEL_ARG" \
            data="$DATASET_YAML" \
            epochs="$EPOCHS" \
            batch="$BATCH" \
            imgsz="$IMG_SIZE" \
            workers="$WORKERS" \
            lr0="$LR0" \
            lrf="$LRF" \
            momentum="$MOMENTUM" \
            weight_decay="$WEIGHT_DECAY" \
            patience="$PATIENCE" \
            device="$DEVICE" \
            project="$OUTPUT_DIR/$PROJECT_NAME" \
            name="$RUN_NAME" \
            $RESUME_FLAG \
            $EXTRA_ARGS
        ;;

    dist)
        SCRIPT=""; NPROC="${SLURM_NTASKS_PER_NODE:-1}"; PORT=29500; PASSTHROUGH=()
        while [[ $# -gt 0 ]]; do
            case "$1" in
                --script)      SCRIPT="$2"; shift 2 ;;
                --nproc)       NPROC="$2";  shift 2 ;;
                --master-port) PORT="$2";   shift 2 ;;
                -h|--help) exec /opt/entrypoint.sh help ;;
                --) shift; PASSTHROUGH+=("$@"); break ;;
                *) echo "[ERROR] Unknown flag: $1"; exec /opt/entrypoint.sh help ;;
            esac
        done
        [[ -z "$SCRIPT" ]] && { echo "[ERROR] --script required"; exec /opt/entrypoint.sh help; }
        [[ "$GPU_COUNT" -eq 0 ]] && echo "[WARN] No GPU — CPU mode"
        exec torchrun --nproc_per_node="$NPROC" --master_port="$PORT" \
            "$SCRIPT" "${PASSTHROUGH[@]+${PASSTHROUGH[@]}}"
        ;;

    jupyter)
        PORT=8888
        while [[ $# -gt 0 ]]; do
            case "$1" in
                --port) PORT="$2"; shift 2 ;;
                -h|--help) exec /opt/entrypoint.sh help ;;
                *) echo "[ERROR] Unknown flag: $1"; exec /opt/entrypoint.sh help ;;
            esac
        done
        exec jupyter lab --no-browser --ip=0.0.0.0 --port="$PORT" \
            --notebook-dir=/code \
            --ServerApp.token='' --ServerApp.password=''
        ;;

    info)  _info ;;
    bash)  exec /bin/bash ;;

    help|-h|--help)
        cat << 'HELPEOF'
Usage: apptainer exec --nv <container>.sif [MODE] [ARGS...]
  train   --data PATH --variant n|s|m|l|x [--classes C] [--epochs N] [--batch N]
          [--img-size N] [--workers N] [--device ID] [--output PATH]
          [--project NAME] [--run NAME] [--lr0 F] [--lrf F] [--momentum F]
          [--weight-decay F] [--patience N] [--resume] [--extra "..."]
  dist    --script PATH [--nproc N] [--master-port N]
  jupyter [--port N]
  info / bash / <cmd>
Run: apptainer run-help <container>.sif  for full docs.
HELPEOF
        ;;

    *) exec "$MODE" "$@" ;;
esac
ENTRYPOINT_SCRIPT

    chmod +x /opt/entrypoint.sh

# ─────────────────────────────────────────────────────────────────────────────
# ENVIRONMENT
# ─────────────────────────────────────────────────────────────────────────────
%environment
    export PATH=/usr/local/bin:$PATH
    export PYTHONDONTWRITEBYTECODE=1
    export PYTHONUNBUFFERED=1
    export HF_HUB_DISABLE_TELEMETRY=1
    export OMP_NUM_THREADS=${SLURM_CPUS_PER_TASK:-4}
    export MPLBACKEND=Agg
    export PIP_CONSTRAINT=/etc/pip/constraint.txt
    export NCCL_DEBUG=WARN
    export NCCL_IB_DISABLE=0
    export YOLO_TELEMETRY=False
    export YOLO_CONFIG_DIR=/tmp/ultralytics

# ─────────────────────────────────────────────────────────────────────────────
# STARTSCRIPT
# ─────────────────────────────────────────────────────────────────────────────
%startscript
    [ -z "$BASH" ] && exec /bin/bash "$0" "$@"
    mkdir -p /tmp/ultralytics
    mkdir -p /tmp/torch_cache && export TORCH_HOME=/tmp/torch_cache
    mkdir -p /tmp/hf_cache    && export HF_HOME=/tmp/hf_cache
    exec /opt/entrypoint.sh "$@"

# ─────────────────────────────────────────────────────────────────────────────
# RUNSCRIPT
# ─────────────────────────────────────────────────────────────────────────────
%runscript
    [ -z "$BASH" ] && exec /bin/bash "$0" "$@"
    if [ $# -eq 0 ]; then
        /opt/entrypoint.sh help
        exec /bin/bash
    else
        exec /opt/entrypoint.sh "$@"
    fi

# ─────────────────────────────────────────────────────────────────────────────
# HELP   apptainer run-help yolo11-8.3.40-cuda12.1-detect-v7.0.0.sif
# ─────────────────────────────────────────────────────────────────────────────
%help
================================================================================
  yolo11-8.3.40-cuda12.1-detect-v7.0.0.sif
  YOLO11 object-detection training. All 5 YOLOv11 sizes baked in.
  Does NOT include: roboflow (conflicts with headless cv2; requires internet).
  Base: pytorch/pytorch:2.2.0-cuda12.1-cudnn8-runtime  |  Python: 3.11
================================================================================

BUILD
  sudo apptainer build yolo11-8.3.40-cuda12.1-detect-v7.0.0.sif yolo.def
  apptainer build --fakeroot yolo11-8.3.40-cuda12.1-detect-v7.0.0.sif yolo.def
  (Downloads yolo11n/s/m/l/x.pt at build time. Compute nodes need no internet.)

--------------------------------------------------------------------------------
BIND POINTS
--------------------------------------------------------------------------------
  /code    Project source      /home/$USER/myproject/code
  /data    Input datasets      /home/$USER/myproject/data
  /output  Results, ckpts      /home/$USER/myproject/output
  /model   Pretrained weights  /home/$USER/myproject/model
  /scratch Node-local temp     $TMPDIR or /tmp/scratch
  $HOME and /tmp auto-mounted by Apptainer.

--------------------------------------------------------------------------------
APPTAINER FLAGS
--------------------------------------------------------------------------------
  --nv              Pass NVIDIA GPU(s) into container
  --bind src:dst    Mount host path at container path
  --env KEY=VALUE   Set env var inside container
  --writable-tmpfs  Writable overlay on read-only .sif
  --no-home         Do not auto-mount $HOME
  --cleanenv        Clear host environment

  exec → run command   run → invoke %runscript   shell → interactive

--------------------------------------------------------------------------------
ENTRYPOINT MODES
--------------------------------------------------------------------------------

  train   Single-GPU or CPU YOLO training
    --data PATH         Dataset dir OR path to a .yaml file          [required]
    --variant n|s|m|l|x YOLOv11 size (ignored if custom.pt mounted) [default: n]
    --classes NAMES     Comma-sep class names (skip for .yaml data)
    --epochs N                                                        [default: 100]
    --batch N                                                         [default: 16]
    --img-size N        Input resolution pixels                       [default: 640]
    --workers N         DataLoader workers                            [default: 8]
    --device ID         GPU id(s) or 'cpu'                            [default: 0]
    --output PATH       Output dir inside container                   [default: /output]
    --project NAME      Sub-folder                                    [default: yolo_train]
    --run NAME          Experiment name                               [default: exp]
    --lr0 F             Initial learning rate                         [default: 0.01]
    --lrf F             Final LR fraction                             [default: 0.01]
    --momentum F                                                      [default: 0.937]
    --weight-decay F                                                  [default: 0.0005]
    --patience N        Early-stop patience                           [default: 50]
    --resume            Resume from last checkpoint
    --extra "..."       Extra Ultralytics CLI args passed verbatim

    Example:
      apptainer exec --nv \
        --bind /home/$USER/proj/data:/data \
        --bind /home/$USER/proj/output:/output \
        yolo11-8.3.40-cuda12.1-detect-v7.0.0.sif \
        train --variant m --data /data --classes "cat,dog,car" \
        --epochs 100 --batch 32 --device 0

  dist    Distributed training via torchrun (DDP)
    --script PATH       Python training script                        [required]
    --nproc N           Processes per node        [default: $SLURM_NTASKS_PER_NODE]
    --master-port N     torchrun master port                          [default: 29500]
    -- ARGS             Extra args forwarded to the script

    Example:
      apptainer exec --nv \
        --bind /home/$USER/proj/code:/code \
        --bind /home/$USER/proj/data:/data \
        --bind /home/$USER/proj/output:/output \
        yolo11-8.3.40-cuda12.1-detect-v7.0.0.sif \
        dist --script /code/train_ddp.py --nproc 4

  jupyter Headless JupyterLab (SSH port-forward to access)
    --port N            Listening port                                [default: 8888]

    Example:
      apptainer exec --nv \
        --bind /home/$USER/proj/code:/code \
        yolo11-8.3.40-cuda12.1-detect-v7.0.0.sif jupyter --port 8888
      # On your laptop: ssh -L 8888:localhost:8888 user@login-node
      # Then open: http://localhost:8888

  info    Print framework versions + GPU inventory
  bash    Interactive shell
  <cmd>   Passthrough — run any command directly

--------------------------------------------------------------------------------
SLURM INTEGRATION
--------------------------------------------------------------------------------

  Single-node, 4 GPUs:

    #!/bin/bash
    #SBATCH --nodes=1 --ntasks=1 --cpus-per-task=16
    #SBATCH --gres=gpu:4 --mem=64G --time=08:00:00
    SIF=/home/$USER/containers/yolo11-8.3.40-cuda12.1-detect-v7.0.0.sif
    apptainer exec --nv \
      --bind /home/$USER/proj/data:/data \
      --bind /home/$USER/proj/output:/output \
      $SIF train --variant m --data /data --classes "cat,dog" \
      --epochs 100 --batch 32 --device 0,1,2,3

  Multi-node DDP, 2 × 4 GPUs:

    #!/bin/bash
    #SBATCH --nodes=2 --ntasks-per-node=1 --cpus-per-task=16
    #SBATCH --gres=gpu:4 --time=12:00:00
    SIF=/home/$USER/containers/yolo11-8.3.40-cuda12.1-detect-v7.0.0.sif
    srun apptainer exec --nv \
      --bind /home/$USER/proj/code:/code \
      --bind /home/$USER/proj/data:/data \
      --bind /home/$USER/proj/output:/output \
      $SIF dist --script /code/train_ddp.py --nproc 4

  CPU-only:

    #!/bin/bash
    #SBATCH --nodes=1 --ntasks=1 --cpus-per-task=32 --mem=32G
    apptainer exec \
      --bind /home/$USER/proj/data:/data \
      --bind /home/$USER/proj/output:/output \
      $SIF train --variant n --data /data --classes "person" --device cpu

--------------------------------------------------------------------------------
TWO-PHASE WORKFLOW
--------------------------------------------------------------------------------
  Phase 1 (login node): wget / git clone your dataset → Lustre
  Phase 2 (compute node): bind Lustre paths — no network calls needed

--------------------------------------------------------------------------------
WEIGHTS: TWO MODES
--------------------------------------------------------------------------------

  MODE 1 (default) · Built-in YOLOv11 weights (no internet needed at runtime)
    --variant n   yolo11n  ~5 MB   fastest / lowest accuracy
    --variant s   yolo11s  ~19 MB
    --variant m   yolo11m  ~38 MB  good balance
    --variant l   yolo11l  ~49 MB
    --variant x   yolo11x  ~109 MB slowest / highest accuracy

  MODE 2 · Your own .pt file (bind-mount override)
    Bind to: /opt/yolo_weights/custom.pt
    When present, --variant is ignored and your model is used instead.
    Works with any Ultralytics-compatible .pt (v8/v9/v10/v11).

    apptainer exec --nv \
      --bind /models/my_model.pt:/opt/yolo_weights/custom.pt \
      --bind /data:/data --bind /results:/output \
      yolo11-8.3.40-cuda12.1-detect-v7.0.0.sif \
      train --data /data --classes "cat,dog" --epochs 50

--------------------------------------------------------------------------------
USER VENV WORKFLOW
--------------------------------------------------------------------------------
  apptainer exec yolo11-8.3.40-cuda12.1-detect-v7.0.0.sif bash
  python3 -m venv --system-site-packages $HOME/envs/yolo-ext
  source $HOME/envs/yolo-ext/bin/activate
  unset PIP_CONSTRAINT    # required — releases base env lock
  pip install <extra-packages>

  venvs live in $HOME (Lustre-backed), survive container updates.

--------------------------------------------------------------------------------
CUDA DRIVER COMPATIBILITY
--------------------------------------------------------------------------------
  Container CUDA   Min host driver   Tested range
  12.1             525.60            12.1–12.4+
  Check host driver: nvidia-smi

--------------------------------------------------------------------------------
CPU FALLBACK
--------------------------------------------------------------------------------
  Omit --nv / --gres=gpu. A warning is printed at startup; training continues.
  Test: CUDA_VISIBLE_DEVICES="" apptainer exec yolo11-8.3.40-cuda12.1-detect-v7.0.0.sif info

--------------------------------------------------------------------------------
INSTALLED PACKAGES
--------------------------------------------------------------------------------
  torch                2.2.0        (from base image)
  ultralytics          8.3.40
  numpy                1.26.4
  opencv-headless      4.9.0.80
  Pillow               10.3.0
  PyYAML               6.0.1
  matplotlib           3.8.4
  seaborn              0.13.2
  pandas               2.2.2
  scipy                1.13.1
  tensorboard          2.16.2
  tqdm                 4.66.4
  psutil               5.9.8
  py-cpuinfo           9.0.0
  jupyterlab           4.2.5
  pip                  24.0
  setuptools           69.5.1
  wheel                0.43.0

  NOTE — roboflow excluded: conflicts with opencv-python-headless (shared cv2
  namespace); also requires internet + account at runtime — unsuitable for
  air-gapped HPC compute nodes. Download datasets on a login node.
================================================================================
