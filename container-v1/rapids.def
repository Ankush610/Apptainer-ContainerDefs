Bootstrap: docker
From: nvcr.io/nvidia/rapidsai/base:24.10-cuda12.5-py3.11

%labels
    Maintainer       Ankush / CDAC Pune
    Org              CDAC
    Version          1.2.0
    Framework        RAPIDS 24.10 (cuDF, cuML, cuGraph, cuSpatial, RAFT)
    CUDA_Version     12.5
    CUDA_Driver_Min  525.85.12
    CUDA_Range       525.85.12 – 570.x (tested)
    Python_Version   3.11
    CPU_Capable      yes
    Description      GPU-accelerated ML/DS with RAPIDS cuDF, cuML, cuGraph. Includes XGBoost-GPU, pandas, scikit-learn, matplotlib, seaborn, plotly, optuna, JupyterLab. No deep learning / no PyTorch / no TensorFlow.
    Modes            train, dist, jupyter, info, bash

# ─────────────────────────────────────────────────────────────────────────────
# %setup  — runs on the HOST before %post, used only for host-side prep
# ─────────────────────────────────────────────────────────────────────────────
%setup
    # Fix APT sandbox issue on some host distros
    mkdir -p ${SINGULARITY_ROOTFS}/etc/apt/apt.conf.d
    echo 'APT::Sandbox::User "root";' \
      > ${SINGULARITY_ROOTFS}/etc/apt/apt.conf.d/99sandbox-fix

    # Bind-point directories (empty placeholders; real data lives on host/Lustre)
    mkdir -p ${SINGULARITY_ROOTFS}/code
    mkdir -p ${SINGULARITY_ROOTFS}/data
    mkdir -p ${SINGULARITY_ROOTFS}/output
    mkdir -p ${SINGULARITY_ROOTFS}/model
    mkdir -p ${SINGULARITY_ROOTFS}/scratch

# ─────────────────────────────────────────────────────────────────────────────
# %post  — everything installed inside the container
# ─────────────────────────────────────────────────────────────────────────────
%post
    [ -z "$BASH" ] && exec /bin/bash "$0" "$@"
    set -euo pipefail
    export DEBIAN_FRONTEND=noninteractive

    # ── System packages ───────────────────────────────────────────────────────
    # Only adding what the RAPIDS base image doesn't ship.
    # Covers: GL/display libs for matplotlib/plotly, InfiniBand for MPI,
    # build-essential for any C-extension wheels, and common utilities.
    apt-get update
    apt-get install -y --no-install-recommends liburcu8 liburcu-dev \
        wget curl git unzip zip ca-certificates \
        ffmpeg \
        libgl1-mesa-glx libgl1 \
        libglib2.0-0 libsm6 libxrender1 libxext6 \
        libgomp1 build-essential \
        libibverbs1 librdmacm1 ibverbs-utils \
      	vim
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    # ── Python additions ──────────────────────────────────────────────────────
    # Strategy: touch ONLY what is absent from the RAPIDS base image.
    # The base already provides:
    #   cuDF, cuML, cuGraph, numpy, pandas, scikit-learn, scipy, statsmodels,
    #   xgboost, matplotlib, plotly, optuna, tqdm, rich, joblib, Pillow,
    #   PyYAML, psutil — do NOT reinstall or upgrade any of these.
    #
    # We add only JupyterLab, which is genuinely missing from the base.
    # If you need seaborn / lightgbm / imbalanced-learn / py-cpuinfo later,
    # install them in a user venv (see %help → USER VENV WORKFLOW).
    pip install --upgrade pip setuptools wheel
    
    pip install \
     jupyterlab==4.3.0 \
     seaborn==0.13.2 \
     lightgbm==4.5.0 \
     catboost==1.2.7 \
     imbalanced-learn==0.12.4 \
     py-cpuinfo==9.0.0

    pip install jupyterlab==4.3.0

    # Freeze the full environment so user venvs can detect what's locked.
    mkdir -p /etc/pip
    pip freeze > /etc/pip/constraint.txt

    # ── Entrypoint script ─────────────────────────────────────────────────────
    cat > /opt/entrypoint.sh << 'ENTRYEOF'
#!/bin/bash
set -euo pipefail

MODE="${1:-help}"
shift 2>/dev/null || true

GPU_COUNT=$(nvidia-smi --query-gpu=name --format=csv,noheader 2>/dev/null | wc -l || echo 0)

# ── info helper ───────────────────────────────────────────────────────────────
_info() {
    python3 - <<'EOF'
import sys, subprocess

def ver(mod, attr='__version__'):
    try:
        v = getattr(mod, attr, None)
        if v is None:
            import importlib.metadata
            v = importlib.metadata.version(mod.__name__)
        return str(v)
    except Exception:
        return '(version unknown)'

import cudf, cuml, cugraph
import numpy, pandas, sklearn, scipy, xgboost
import matplotlib, plotly, optuna, statsmodels
import PIL, joblib, tqdm, yaml, psutil, rich
import jupyterlab, seaborn, lightgbm, catboost, imblearn, cpuinfo

print(f"Python:        {sys.version.split()[0]}")
print(f"cuDF:          {ver(cudf)}")
print(f"cuML:          {ver(cuml)}")
print(f"cuGraph:       {ver(cugraph)}")
print(f"NumPy:         {ver(numpy)}")
print(f"pandas:        {ver(pandas)}")
print(f"scikit-learn:  {ver(sklearn)}")
print(f"XGBoost:       {ver(xgboost)}")
print(f"scipy:         {ver(scipy)}")
print(f"statsmodels:   {ver(statsmodels)}")
print(f"matplotlib:    {ver(matplotlib)}")
print(f"plotly:        {ver(plotly)}")
print(f"optuna:        {ver(optuna)}")
print(f"jupyterlab:    {ver(jupyterlab)}")
print(f"seaborn:       {ver(seaborn)}")
print(f"lightgbm:      {ver(lightgbm)}")
print(f"catboost:      {ver(catboost)}")
print(f"imblearn:      {ver(imblearn)}")
print(f"cpuinfo:       {ver(cpuinfo)}")
print(f"Pillow:        {ver(PIL, 'VERSION')}")
print(f"joblib:        {ver(joblib)}")
print(f"tqdm:          {ver(tqdm)}")
print(f"PyYAML:        {ver(yaml)}")
print(f"psutil:        {ver(psutil)}")
print(f"rich:          {ver(rich)}")

try:
    r = subprocess.run(
        ['nvidia-smi', '--query-gpu=name,memory.total', '--format=csv,noheader'],
        capture_output=True, text=True
    )
    if r.returncode == 0 and r.stdout.strip():
        print("GPUs:")
        for i, line in enumerate(r.stdout.strip().split('\n')):
            print(f"  GPU {i}: {line}")
    else:
        print("No GPU detected — CPU fallback active")
except FileNotFoundError:
    print("No GPU detected — CPU fallback active")

try:
    import cudf
    df = cudf.DataFrame({'x': [1, 2, 3]})
    print(f"cuDF GPU test: OK ({len(df)} rows)")
except Exception as e:
    print(f"cuDF GPU test: SKIPPED ({e})")
EOF
}

# ── Mode dispatcher ───────────────────────────────────────────────────────────
case "$MODE" in

    # ── train ─────────────────────────────────────────────────────────────────
    train)
        SCRIPT=""
        GPU_ID=0
        PASSTHROUGH_ARGS=()
        while [[ $# -gt 0 ]]; do
            case "$1" in
                --script) SCRIPT="$2"; shift 2 ;;
                --gpu)    GPU_ID="$2"; shift 2 ;;
                -h|--help) exec /opt/entrypoint.sh help ;;
                --) shift; PASSTHROUGH_ARGS+=("$@"); break ;;
                *) echo "[ERROR] Unknown flag: $1"; exec /opt/entrypoint.sh help ;;
            esac
        done
        [[ -z "$SCRIPT" ]] && { echo "[ERROR] --script PATH is required"; exec /opt/entrypoint.sh help; }
        if [ "$GPU_COUNT" -eq 0 ]; then
            echo "[WARN] No GPU detected — running in CPU mode (cuDF/cuML will fall back to CPU)"
        fi
        exec python3 "$SCRIPT" "${PASSTHROUGH_ARGS[@]+"${PASSTHROUGH_ARGS[@]}"}"
        ;;

    # ── dist ──────────────────────────────────────────────────────────────────
    # Sets OMP_NUM_THREADS + JOBLIB_NUM_THREADS for parallel CPU/Dask workloads.
    # For multi-GPU Dask-CUDA, manage LocalCUDACluster directly in your script.
    dist)
        SCRIPT=""
        NPROC="${SLURM_CPUS_PER_TASK:-4}"
        PASSTHROUGH_ARGS=()
        while [[ $# -gt 0 ]]; do
            case "$1" in
                --script) SCRIPT="$2"; shift 2 ;;
                --nproc)  NPROC="$2"; shift 2 ;;
                -h|--help) exec /opt/entrypoint.sh help ;;
                --) shift; PASSTHROUGH_ARGS+=("$@"); break ;;
                *) echo "[ERROR] Unknown flag: $1"; exec /opt/entrypoint.sh help ;;
            esac
        done
        [[ -z "$SCRIPT" ]] && { echo "[ERROR] --script PATH is required"; exec /opt/entrypoint.sh help; }
        if [ "$GPU_COUNT" -eq 0 ]; then
            echo "[WARN] No GPU detected — running in CPU mode"
        fi
        export OMP_NUM_THREADS="$NPROC"
        export JOBLIB_NUM_THREADS="$NPROC"
        echo "[INFO] dist mode: OMP_NUM_THREADS=$NPROC, JOBLIB_NUM_THREADS=$NPROC"
        echo "[INFO] For multi-GPU Dask-CUDA, manage LocalCUDACluster in your script."
        exec python3 "$SCRIPT" "${PASSTHROUGH_ARGS[@]+"${PASSTHROUGH_ARGS[@]}"}"
        ;;

    # ── jupyter ───────────────────────────────────────────────────────────────
    jupyter)
        PORT=8888
        while [[ $# -gt 0 ]]; do
            case "$1" in
                --port) PORT="$2"; shift 2 ;;
                -h|--help) exec /opt/entrypoint.sh help ;;
                *) echo "[ERROR] Unknown flag: $1"; exec /opt/entrypoint.sh help ;;
            esac
        done
        if [ "$GPU_COUNT" -eq 0 ]; then
            echo "[WARN] No GPU detected — JupyterLab will run in CPU mode"
        fi
        exec jupyter lab \
            --no-browser \
            --ip=0.0.0.0 \
            --port="$PORT" \
            --notebook-dir=/code \
            --ServerApp.token='' \
            --ServerApp.password=''
        ;;

    # ── info / bash / help / passthrough ─────────────────────────────────────
    info)
        _info
        ;;

    bash)
        exec /bin/bash
        ;;

    help|--help|-h)
        cat << 'HELPEOF'
Usage: apptainer exec --nv <container>.sif [MODE] [ARGS...]
  train   --script PATH [--gpu ID] [-- ARGS]
  dist    --script PATH [--nproc N] [-- ARGS]
  jupyter [--port N]
  info
  bash
  <cmd>   passthrough (any unrecognised first arg is exec'd directly)
Run: apptainer run-help <container>.sif  for full documentation.
HELPEOF
        ;;

    *)
        exec "$MODE" "$@"
        ;;
esac
ENTRYEOF

    chmod +x /opt/entrypoint.sh

    # ── Smoke test ────────────────────────────────────────────────────────────
    # Uses safe_import so a missing package prints [MISSING] instead of
    # crashing the build. Check the WARNING lines manually after build.
    python3 -c "
import sys
print('Python:', sys.version)

def ver(mod, attr='__version__'):
    try:
        v = getattr(mod, attr, None)
        if v is None:
            import importlib.metadata
            v = importlib.metadata.version(mod.__name__)
        return str(v)
    except Exception:
        return '(version unknown)'

def safe_import(name, attr=None):
    try:
        import importlib
        mod = importlib.import_module(name)
        version = ver(mod, attr) if attr else ver(mod)
        return mod, version
    except ImportError:
        print(f'[WARNING] MISSING package: {name} — not found in container')
        return None, 'MISSING'

packages = [
    ('cudf',        None,      'cuDF         '),
    ('cuml',        None,      'cuML         '),
    ('cugraph',     None,      'cuGraph      '),
    ('numpy',       None,      'NumPy        '),
    ('pandas',      None,      'pandas       '),
    ('sklearn',     None,      'scikit-learn '),
    ('xgboost',     None,      'XGBoost      '),
    ('scipy',       None,      'scipy        '),
    ('statsmodels', None,      'statsmodels  '),
    ('matplotlib',  None,      'matplotlib   '),
    ('plotly',      None,      'plotly       '),
    ('optuna',      None,      'optuna       '),
    ('PIL',         'VERSION', 'Pillow       '),
    ('tqdm',        None,      'tqdm         '),
    ('yaml',        None,      'PyYAML       '),
    ('psutil',      None,      'psutil       '),
    ('rich',        None,      'rich         '),
    ('joblib',      None,      'joblib       '),
    ('jupyterlab',  None,      'jupyterlab   '),
]

missing = []
for mod_name, attr, label in packages:
    mod, version = safe_import(mod_name, attr) if attr else safe_import(mod_name)
    status = version if version != 'MISSING' else 'MISSING ← CHECK MANUALLY'
    print(f'{label}: {status}')
    if version == 'MISSING':
        missing.append(mod_name)

try:
    import subprocess
    r = subprocess.run(
        ['nvidia-smi', '--query-gpu=name,memory.total', '--format=csv,noheader'],
        capture_output=True, text=True
    )
    if r.returncode == 0 and r.stdout.strip():
        for i, line in enumerate(r.stdout.strip().split('\n')):
            print(f'  GPU {i}: {line}')
    else:
        print('nvidia-smi: no GPU visible in build env — OK')
except FileNotFoundError:
    print('nvidia-smi not found in build env — GPU check skipped (expected)')

if missing:
    print()
    print('BUILD WARNING: the following packages were not found:')
    for m in missing:
        print(f'  - {m}')
    print('Build continues. Verify manually: apptainer exec <container>.sif info')
else:
    print('ALL IMPORTS OK')
"

    # Verify critical shared libraries are resolvable
    ldconfig
    ls /usr/lib/x86_64-linux-gnu/libGL.so.1 \
       /usr/lib/x86_64-linux-gnu/libibverbs.so.1 2>/dev/null \
    || true

# ─────────────────────────────────────────────────────────────────────────────
# %environment  — vars set every time the container starts
# ─────────────────────────────────────────────────────────────────────────────
%environment
    export PATH=/usr/local/bin:$PATH
    export PYTHONDONTWRITEBYTECODE=1
    export PYTHONUNBUFFERED=1
    export PIP_CONSTRAINT=/etc/pip/constraint.txt
    export HF_HUB_DISABLE_TELEMETRY=1
    export OMP_NUM_THREADS=${SLURM_CPUS_PER_TASK:-4}
    export NCCL_DEBUG=WARN
    export NCCL_IB_DISABLE=0
    export MPLBACKEND=Agg
    export RAPIDS_NO_INITIALIZE=1

# ─────────────────────────────────────────────────────────────────────────────
# %startscript / %runscript
# ─────────────────────────────────────────────────────────────────────────────
%startscript
    [ -z "$BASH" ] && exec /bin/bash "$0" "$@"
    mkdir -p /tmp/fw_cache /tmp/rapids_cache
    export RAPIDS_CACHE_DIR=/tmp/rapids_cache
    exec /opt/entrypoint.sh "$@"

%runscript
    [ -z "$BASH" ] && exec /bin/bash "$0" "$@"
    if [ $# -eq 0 ]; then
        /opt/entrypoint.sh help
        exec /bin/bash
    else
        exec /opt/entrypoint.sh "$@"
    fi

# ─────────────────────────────────────────────────────────────────────────────
# %help
# ─────────────────────────────────────────────────────────────────────────────
%help
================================================================================
  RAPIDS ML + DS GPU Container  v1.2.0
  RAPIDS 24.10  ·  CUDA 12.5  ·  Python 3.11  ·  GPU-accelerated
  Base image ships: cuDF, cuML, cuGraph, XGBoost, scikit-learn, pandas,
  numpy, scipy, statsmodels, matplotlib, plotly, optuna, tqdm, rich,
  joblib, Pillow, PyYAML, psutil.
  Added on top: JupyterLab 4.3.0 + system libs (GL, InfiniBand, build tools).
  No deep learning / no PyTorch / no TensorFlow.

  Extra packages (seaborn, lightgbm, imbalanced-learn, etc.)?
  → Use the USER VENV WORKFLOW below — zero conflict risk.
================================================================================

BUILD
  sudo apptainer build <container>.sif <container>.def
  apptainer build --fakeroot <container>.sif <container>.def

--------------------------------------------------------------------------------
BIND POINTS
--------------------------------------------------------------------------------
  Container path   Purpose                    Example host path (Lustre)
  ---------------  -------------------------  ----------------------------------
  /code            Project source code        /home/$USER/myproject/code
  /data            Input datasets             /home/$USER/myproject/data
  /output          Results, trained models    /home/$USER/myproject/output
  /model           Pretrained models          /home/$USER/myproject/model
  /scratch         Node-local temp            $TMPDIR  or  /tmp/scratch

  Auto-mounted by Apptainer (no --bind needed):
    $HOME  → your Lustre home dir  (venvs, dotfiles, SSH keys persist here)
    /tmp   → node-local temp

  Multiple binds:
    --bind /src1:/dst1 --bind /src2:/dst2
    --bind /src1:/dst1,/src2:/dst2          (comma-separated, same effect)

--------------------------------------------------------------------------------
APPTAINER FLAGS REFERENCE
--------------------------------------------------------------------------------
  --nv                  Pass NVIDIA GPU(s) into container (required for GPU jobs)
  --bind src:dst        Mount host directory src at container path dst
  --env KEY=VALUE       Set an environment variable inside the container
  --writable-tmpfs      Overlay writable tmpfs on top of read-only .sif
  --no-home             Do NOT auto-mount $HOME (reproducibility tests)
  --pwd /path           Set working directory inside container at launch
  --contain             Isolate container from host filesystem (no auto-mounts)
  --cleanenv            Clear host environment before entering container
  -H /alt/home          Use an alternate home directory

  EXEC vs RUN vs SHELL:
    apptainer exec  <container>.sif <cmd>   → run a specific command
    apptainer run   <container>.sif [args]  → invoke entrypoint (%runscript)
    apptainer shell <container>.sif         → interactive shell

--------------------------------------------------------------------------------
ENTRYPOINT MODES
--------------------------------------------------------------------------------

  TRAIN — single GPU or CPU
  ──────────────────────────
  Flags:
    --script PATH     Path to training script inside the container (required)
    --gpu    ID       GPU device to use (default: 0; ignored on CPU-only nodes)
    -- ARGS           Everything after -- is forwarded to your script as-is

  Examples:
    apptainer exec --nv \
      --bind /home/$USER/proj/code:/code \
      --bind /home/$USER/proj/data:/data \
      --bind /home/$USER/proj/output:/output \
      <container>.sif train --script /code/train.py -- --n-estimators 500

    # CPU-only node (no --nv)
    apptainer exec \
      --bind /home/$USER/proj/code:/code \
      <container>.sif train --script /code/train.py

  DIST — parallel workload using allocated cores (Dask-CUDA for multi-GPU)
  ─────────────────────────────────────────────────────────────────────────
  Sets OMP_NUM_THREADS and JOBLIB_NUM_THREADS for scikit-learn / joblib parallelism.
  For multi-GPU Dask-CUDA, manage LocalCUDACluster inside your script:

    from dask_cuda import LocalCUDACluster
    from dask.distributed import Client
    cluster = LocalCUDACluster()
    client = Client(cluster)

  Flags:
    --script PATH     Training script (required)
    --nproc  N        Number of CPU threads (default: SLURM_CPUS_PER_TASK or 4)
    -- ARGS           Forwarded to your script

  Examples:
    apptainer exec --nv \
      --bind /home/$USER/proj/code:/code \
      <container>.sif dist --script /code/train.py --nproc 32

    # SLURM picks up thread count automatically:
    apptainer exec --nv \
      --bind /home/$USER/proj/code:/code \
      <container>.sif dist --script /code/train.py

  JUPYTER — headless JupyterLab, access via SSH tunnel
  ──────────────────────────────────────────────────────
  Flags:
    --port N    JupyterLab port (default: 8888)

  Examples:
    apptainer exec --nv \
      --bind /home/$USER/proj/code:/code \
      <container>.sif jupyter --port 8888

  SSH tunnel workflow:
    1. Launch jupyter inside SLURM job or interactive session on compute node
    2. Note the compute node hostname (check $SLURM_NODELIST or hostname)
    3. On your LOCAL machine:
         ssh -L 8888:<compute-node-hostname>:8888 <username>@<login-node>
    4. Open http://localhost:8888 in your local browser
    5. No token/password required (disabled for HPC use)

  INFO — print environment and hardware details
  ───────────────────────────────────────────────
    apptainer exec --nv <container>.sif info
    apptainer run  --nv <container>.sif info

  BASH — interactive shell
  ─────────────────────────
    apptainer exec --nv --bind /home/$USER/proj/code:/code <container>.sif bash
    apptainer shell --nv --bind /home/$USER/proj/code:/code <container>.sif

  PASSTHROUGH — run any command directly
  ───────────────────────────────────────
    apptainer exec --nv <container>.sif python3 /code/eval.py
    apptainer exec --nv <container>.sif python3 -c "import cudf; print(cudf.__version__)"
    apptainer exec <container>.sif pip list

--------------------------------------------------------------------------------
SLURM INTEGRATION
--------------------------------------------------------------------------------
  Single-node GPU training:

    #!/bin/bash
    #SBATCH --job-name=rapids_train
    #SBATCH --nodes=1
    #SBATCH --ntasks=1
    #SBATCH --cpus-per-task=16
    #SBATCH --gres=gpu:4
    #SBATCH --mem=64G
    #SBATCH --time=04:00:00
    #SBATCH --output=logs/%j.out

    SIF=/home/$USER/containers/<container>.sif
    CODE=/home/$USER/myproject/code
    DATA=/home/$USER/myproject/data
    OUTPUT=/home/$USER/myproject/output

    apptainer exec --nv \
      --bind $CODE:/code \
      --bind $DATA:/data \
      --bind $OUTPUT:/output \
      $SIF train --script /code/train.py -- --n-estimators 1000

  Multi-GPU Dask-CUDA (manage LocalCUDACluster in your script):

    #!/bin/bash
    #SBATCH --job-name=rapids_dask
    #SBATCH --nodes=1
    #SBATCH --ntasks=1
    #SBATCH --cpus-per-task=32
    #SBATCH --gres=gpu:4
    #SBATCH --mem=128G
    #SBATCH --time=08:00:00
    #SBATCH --output=logs/%j.out

    SIF=/home/$USER/containers/<container>.sif

    apptainer exec --nv \
      --bind /home/$USER/proj/code:/code \
      --bind /home/$USER/proj/data:/data \
      --bind /home/$USER/proj/output:/output \
      $SIF dist --script /code/train.py --nproc 32

  JupyterLab interactive session:

    #!/bin/bash
    #SBATCH --job-name=rapids_jupyter
    #SBATCH --nodes=1
    #SBATCH --ntasks=1
    #SBATCH --cpus-per-task=8
    #SBATCH --gres=gpu:1
    #SBATCH --mem=32G
    #SBATCH --time=02:00:00
    #SBATCH --output=logs/jupyter_%j.out

    SIF=/home/$USER/containers/<container>.sif

    apptainer exec --nv \
      --bind /home/$USER/proj/code:/code \
      $SIF jupyter --port 8888

  CPU-only node (no --nv, no --gres=gpu):

    #!/bin/bash
    #SBATCH --nodes=1
    #SBATCH --ntasks=1
    #SBATCH --cpus-per-task=32
    #SBATCH --mem=32G
    #SBATCH --time=04:00:00

    SIF=/home/$USER/containers/<container>.sif

    apptainer exec \
      --bind /home/$USER/proj/code:/code \
      --bind /home/$USER/proj/data:/data \
      $SIF train --script /code/train.py

--------------------------------------------------------------------------------
TWO-PHASE WORKFLOW
--------------------------------------------------------------------------------
  Compute nodes have NO internet access. Prepare all inputs on the login node.

  Phase 1 — Login node (internet available):
    wget https://example.com/dataset.parquet -P /home/$USER/proj/data/
    git clone https://github.com/yourorg/project /home/$USER/proj/code/

  Phase 2 — Compute node (SLURM job, no internet):
    --bind /home/$USER/proj/code:/code
    --bind /home/$USER/proj/data:/data
    --bind /home/$USER/proj/output:/output
    Container reads from /code, /data; writes to /output.

--------------------------------------------------------------------------------
USER VENV WORKFLOW  (how to install extra packages without conflicts)
--------------------------------------------------------------------------------
  The base container Python is locked via PIP_CONSTRAINT. To add packages
  like seaborn, lightgbm, imbalanced-learn, py-cpuinfo, etc.:

  Create once (login node or interactive session):
    apptainer exec <container>.sif bash
    python3 -m venv --system-site-packages $HOME/envs/myenv
    source $HOME/envs/myenv/bin/activate
    unset PIP_CONSTRAINT          # REQUIRED — releases the base env lock
    pip install seaborn lightgbm imbalanced-learn py-cpuinfo
    deactivate

  Use in a SLURM job:
    apptainer exec --nv \
      --bind /home/$USER/proj/code:/code \
      <container>.sif bash -c "
        source \$HOME/envs/myenv/bin/activate
        unset PIP_CONSTRAINT
        python3 /code/train.py
      "

  Why --system-site-packages?
    Your venv inherits all container packages (cuDF, cuML, numpy, etc.).
    You only install your extra packages — not the full RAPIDS stack again.

  Why unset PIP_CONSTRAINT?
    The container locks the base env to prevent silent overwrites.
    In your venv, you own the environment; the lock is not needed.

  Your venvs live in $HOME (Lustre-backed) and survive container updates.

--------------------------------------------------------------------------------
CUDA DRIVER COMPATIBILITY
--------------------------------------------------------------------------------
  Container CUDA   Minimum host driver   Tested driver range
  ─────────────    ─────────────────────  ───────────────────
  12.5             525.85.12              525.85.12 – 570.x

  Check your host driver:  nvidia-smi
  Container CUDA version must be <= host driver's supported CUDA version.

--------------------------------------------------------------------------------
CPU FALLBACK
--------------------------------------------------------------------------------
  This container runs on CPU-only nodes without modification.
  - cuDF and cuML fall back to CPU (pandas / scikit-learn) when no GPU is present
  - Omit --nv from apptainer exec; omit --gres=gpu from SBATCH
  - Startup warning: "No GPU detected — running in CPU mode"
  - Test: CUDA_VISIBLE_DEVICES="" apptainer exec <container>.sif info

