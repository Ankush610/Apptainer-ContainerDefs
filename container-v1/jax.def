Bootstrap: docker
From: nvidia/cuda:12.4.1-cudnn-runtime-ubuntu22.04

%labels
    Maintainer       Ankush / CDAC Pune
    Org              CDAC
    Version          1.0.0
    Framework        JAX 0.5.3
    CUDA_Version     12.4.1
    CUDA_Driver_Min  525.60
    CUDA_Range       525.60 – tested
    cuDNN_Version    9
    Python_Version   3.11
    CPU_Capable      yes
    Description      JAX 0.5.3 training container (CUDA 12.4, cuDNN 9). Includes jaxlib, optax, flax, numpy, pandas, matplotlib, Pillow, JupyterLab. Does NOT include orbax, chex, rlax, or dm-haiku.
    Modes            train,dist,jupyter,info,bash

%setup
    mkdir -p ${SINGULARITY_ROOTFS}/etc/apt/apt.conf.d
    echo 'APT::Sandbox::User "root";' \
      > ${SINGULARITY_ROOTFS}/etc/apt/apt.conf.d/99sandbox-fix

    mkdir -p ${SINGULARITY_ROOTFS}/code
    mkdir -p ${SINGULARITY_ROOTFS}/data
    mkdir -p ${SINGULARITY_ROOTFS}/output
    mkdir -p ${SINGULARITY_ROOTFS}/model
    mkdir -p ${SINGULARITY_ROOTFS}/scratch

%post
    [ -z "$BASH" ] && exec /bin/bash "$0" "$@"
    set -euo pipefail

    DEBIAN_FRONTEND=noninteractive apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        wget curl git unzip zip ca-certificates \
        ffmpeg libgl1-mesa-glx libgl1 \
        libglib2.0-0 libsm6 libxrender1 libxext6 \
        libgomp1 build-essential vim \
        python3.11 python3.11-dev python3-pip \
        libibverbs1 librdmacm1 ibverbs-utils

    # Bootstrap pip
    python3.11 -m pip install --upgrade pip setuptools wheel

    # numpy first
    python3.11 -m pip install numpy==1.26.4

    # JAX + CUDA 12 plugin-based install (0.5.x plugin style)
    python3.11 -m pip install "jax[cuda12]==0.5.3" jaxlib==0.5.3

    # JAX ecosystem
    python3.11 -m pip install \
        flax==0.10.5 \
        optax==0.2.4 \
        ml-dtypes==0.4.0

    # Data + viz stack
    python3.11 -m pip install \
        pandas==2.2.2 \
        matplotlib==3.9.0 \
        Pillow==10.3.0 \
        scipy==1.13.0

    # JupyterLab
    python3.11 -m pip install jupyterlab==4.2.1

    mkdir -p /etc/pip
    python3.11 -m pip freeze > /etc/pip/constraint.txt

    # --- entrypoint ---
    cat > /opt/entrypoint.sh << 'ENTRYEOF'
#!/bin/bash
set -euo pipefail

MODE="${1:-help}"
shift 2>/dev/null || true

GPU_COUNT=$(nvidia-smi --query-gpu=name --format=csv,noheader 2>/dev/null | wc -l || echo 0)

_info() {
python3.11 - <<'EOF'
import sys, jax
print(f"Python:  {sys.version.split()[0]}")
print(f"JAX:     {jax.__version__}   Devices: {jax.devices()}")
if jax.default_backend() == 'gpu':
    for i, d in enumerate(jax.devices()):
        print(f"  GPU {i}: {d}")
else:
    print("No GPU — CPU mode active")
EOF
}

case "$MODE" in
    train)
        SCRIPT=""
        GPU_ID=""
        EXTRA_ARGS=()
        while [[ $# -gt 0 ]]; do
            case "$1" in
                --script) SCRIPT="$2"; shift 2 ;;
                --gpu)    GPU_ID="$2"; shift 2 ;;
                --)       shift; EXTRA_ARGS+=("$@"); break ;;
                *)        EXTRA_ARGS+=("$1"); shift ;;
            esac
        done
        [[ -z "$SCRIPT" ]] && { echo "ERROR: --script PATH required"; exec /opt/entrypoint.sh help; }
        if [[ "$GPU_COUNT" -eq 0 ]]; then
            echo "[WARNING] No GPU detected — running on CPU"
        fi
        [[ -n "$GPU_ID" ]] && export CUDA_VISIBLE_DEVICES="$GPU_ID"
        exec python3.11 "$SCRIPT" "${EXTRA_ARGS[@]}"
        ;;

    dist)
        SCRIPT=""
        NPROC="${GPU_COUNT:-1}"
        MASTER_PORT=29500
        EXTRA_ARGS=()
        while [[ $# -gt 0 ]]; do
            case "$1" in
                --script)      SCRIPT="$2"; shift 2 ;;
                --nproc)       NPROC="$2"; shift 2 ;;
                --master-port) MASTER_PORT="$2"; shift 2 ;;
                --)            shift; EXTRA_ARGS+=("$@"); break ;;
                *)             EXTRA_ARGS+=("$1"); shift ;;
            esac
        done
        [[ -z "$SCRIPT" ]] && { echo "ERROR: --script PATH required"; exec /opt/entrypoint.sh help; }
        if [[ "$GPU_COUNT" -eq 0 ]]; then
            echo "[WARNING] No GPU detected — running on CPU"
        fi
        # JAX uses jax.distributed.initialize() in-script; launch with python3.11 directly
        exec python3.11 "$SCRIPT" "${EXTRA_ARGS[@]}"
        ;;

    jupyter)
        PORT=8888
        while [[ $# -gt 0 ]]; do
            case "$1" in
                --port) PORT="$2"; shift 2 ;;
                *)      shift ;;
            esac
        done
        exec jupyter lab --no-browser --ip=0.0.0.0 --port "$PORT" \
            --NotebookApp.token='' --NotebookApp.password=''
        ;;

    info)  _info ;;
    bash)  exec /bin/bash ;;

    help|-h|--help)
        cat << 'HELPEOF'
Usage: apptainer exec --nv <container>.sif [MODE] [ARGS...]

  train   --script PATH [--gpu ID] [-- EXTRA_ARGS]
  dist    --script PATH [--nproc N] [--master-port N] [-- EXTRA_ARGS]
  jupyter [--port N]
  info
  bash
  <cmd>   passthrough — exec directly

Run: apptainer run-help <container>.sif  for full documentation.
HELPEOF
        ;;

    *)  exec "$MODE" "$@" ;;
esac
ENTRYEOF
    chmod +x /opt/entrypoint.sh

    # Smoke test
    python3.11 -c "
import sys
print('Python:', sys.version)

def ver(mod, attr='__version__'):
    try:
        v = getattr(mod, attr, None)
        if v is None:
            import importlib.metadata
            v = importlib.metadata.version(mod.__name__)
        return str(v)
    except Exception:
        return '(version unknown)'

def safe_import(name, attr=None):
    try:
        import importlib
        mod = importlib.import_module(name)
        version = ver(mod, attr) if attr else ver(mod)
        return mod, version
    except ImportError:
        print(f'[WARNING] MISSING package: {name} — not found in container')
        return None, 'MISSING'

packages = [
    ('jax',        None,      'JAX          '),
    ('jaxlib',     None,      'jaxlib       '),
    ('flax',       None,      'Flax         '),
    ('optax',      None,      'Optax        '),
    ('ml_dtypes',  None,      'ml-dtypes    '),
    ('numpy',      None,      'NumPy        '),
    ('pandas',     None,      'Pandas       '),
    ('matplotlib', None,      'Matplotlib   '),
    ('PIL',        'VERSION', 'Pillow       '),
    ('scipy',      None,      'SciPy        '),
    ('jupyterlab', None,      'JupyterLab   '),
]

missing = []
for mod_name, attr, label in packages:
    _, version = safe_import(mod_name, attr) if attr else safe_import(mod_name)
    status = version if version != 'MISSING' else 'MISSING <- CHECK MANUALLY'
    print(f'{label}: {status}')
    if version == 'MISSING':
        missing.append(mod_name)

try:
    import subprocess
    r = subprocess.run(['nvidia-smi', '--query-gpu=name,memory.total',
                        '--format=csv,noheader'], capture_output=True, text=True)
    if r.returncode == 0 and r.stdout.strip():
        for i, line in enumerate(r.stdout.strip().split('\n')):
            print(f'  GPU {i}: {line}')
    else:
        print('nvidia-smi: no GPU visible in build env — OK')
except FileNotFoundError:
    print('nvidia-smi not found in build env — GPU check skipped (expected)')

if missing:
    print()
    print('BUILD WARNING: the following packages were not found:')
    for m in missing:
        print(f'  - {m}')
    print('Build continues. Verify manually: apptainer exec <container>.sif info')
else:
    print('ALL IMPORTS OK')
"

    apt-get clean && rm -rf /var/lib/apt/lists/*
    ldconfig
    python3.11 -c "import ctypes; ctypes.CDLL('libcuda.so.1')" 2>/dev/null \
        || echo "libcuda.so.1 not present in build env — expected (runtime-only)"

%environment
    export PATH=/usr/local/bin:$PATH
    export PYTHONDONTWRITEBYTECODE=1
    export PYTHONUNBUFFERED=1
    export PIP_CONSTRAINT=/etc/pip/constraint.txt
    export HF_HUB_DISABLE_TELEMETRY=1
    export OMP_NUM_THREADS=${SLURM_CPUS_PER_TASK:-4}
    export MPLBACKEND=Agg
    export NCCL_DEBUG=WARN
    export NCCL_IB_DISABLE=0
    export JAX_PLATFORM_NAME=cuda

%startscript
    [ -z "$BASH" ] && exec /bin/bash "$0" "$@"
    mkdir -p /tmp/jax_cache /tmp/hf_cache
    export JAX_CACHE_DIR=/tmp/jax_cache
    export XLA_FLAGS="--xla_gpu_cuda_data_dir=/usr/local/cuda"
    export HF_HOME=/tmp/hf_cache
    exec /opt/entrypoint.sh "$@"

%runscript
    [ -z "$BASH" ] && exec /bin/bash "$0" "$@"
    if [ $# -eq 0 ]; then
        /opt/entrypoint.sh help
        exec /bin/bash
    else
        exec /opt/entrypoint.sh "$@"
    fi

%help
================================================================================
  JAX 0.5.3 + CUDA 12.4 Training Container  v1.0.0
  Single and multi-node JAX training. Includes optax, flax, numpy, pandas,
  matplotlib, Pillow, scipy, JupyterLab. Does NOT include orbax, chex, rlax,
  or dm-haiku.
================================================================================

BUILD
  sudo apptainer build <container>.sif <def>.def
  apptainer build --fakeroot <container>.sif <def>.def

--------------------------------------------------------------------------------
BIND POINTS
--------------------------------------------------------------------------------
  /code    Project source code    $HOME/code   (e.g. /home/username/code)
  /data    Input datasets         $HOME/data
  /output  Checkpoints, results   $HOME/output
  /model   Pretrained weights     $HOME/model
  /scratch Node-local temp        $TMPDIR or /tmp/scratch
  $HOME and /tmp are auto-mounted by Apptainer.

  Example bind flag:
    --bind $HOME/code:/code,$HOME/data:/data,$HOME/output:/output,$HOME/model:/model

--------------------------------------------------------------------------------
APPTAINER FLAGS
--------------------------------------------------------------------------------
  --nv                Pass NVIDIA GPU(s) into container
  --bind src:dst      Mount host path at container path
  --env KEY=VALUE     Set env var inside container
  --writable-tmpfs    Writable overlay on read-only .sif
  --no-home           Do not auto-mount $HOME
  --cleanenv          Clear host environment before entering

  exec  → run specific command   run   → invoke %runscript   shell → interactive

--------------------------------------------------------------------------------
ENTRYPOINT MODES
--------------------------------------------------------------------------------
  train
    --script PATH    Python script to run (required)
    --gpu ID         Override GPU index (optional; normally set by SLURM)
    -- ARGS          Extra args forwarded to script

    apptainer exec --nv \
      --bind $HOME/code:/code,$HOME/data:/data,$HOME/output:/output \
      <container>.sif train --script /code/train.py -- --epochs 50

  dist
    --script PATH    Script that calls jax.distributed.initialize() (required)
    --nproc N        Number of processes (informational; JAX handles via env)
    --master-port N  Master port (default 29500)

    apptainer exec --nv \
      --bind $HOME/code:/code,$HOME/output:/output \
      <container>.sif dist --script /code/train_dist.py

    For multi-node distributed training, set SLURM env vars and call
    jax.distributed.initialize() inside your script.

  jupyter
    --port N         Port for JupyterLab (default 8888)

    apptainer exec --nv \
      --bind $HOME/code:/code,$HOME/data:/data \
      <container>.sif jupyter --port 8888

  info   Print JAX version + device list
  bash   Interactive shell
  <cmd>  Passthrough — exec directly

--------------------------------------------------------------------------------
SLURM INTEGRATION
--------------------------------------------------------------------------------
  Single-node GPU:
    #!/bin/bash
    #SBATCH --job-name=jax-train
    #SBATCH --gres=gpu:1
    #SBATCH --cpus-per-task=8
    #SBATCH --mem=32G
    #SBATCH --time=04:00:00
    apptainer exec --nv \
      --bind $HOME/code:/code,$HOME/data:/data,$HOME/output:/output \
      <container>.sif train --script /code/train.py

  Multi-node (2 nodes, 4 GPUs each):
    #!/bin/bash
    #SBATCH --job-name=jax-dist
    #SBATCH --nodes=2
    #SBATCH --ntasks-per-node=1
    #SBATCH --gres=gpu:4
    #SBATCH --cpus-per-task=16
    #SBATCH --mem=64G
    #SBATCH --time=08:00:00
    export MASTER_ADDR=$(scontrol show hostname $SLURM_NODELIST | head -1)
    export MASTER_PORT=29500
    srun apptainer exec --nv \
      --bind $HOME/code:/code,$HOME/data:/data,$HOME/output:/output \
      <container>.sif dist --script /code/train_dist.py

    Your script must call jax.distributed.initialize() and read
    MASTER_ADDR / MASTER_PORT from environment.

  CPU-only:
    #!/bin/bash
    #SBATCH --job-name=jax-cpu
    #SBATCH --cpus-per-task=8
    #SBATCH --mem=16G
    apptainer exec \
      --bind $HOME/code:/code,$HOME/data:/data,$HOME/output:/output \
      <container>.sif train --script /code/train.py

--------------------------------------------------------------------------------
TWO-PHASE WORKFLOW
--------------------------------------------------------------------------------
  Phase 1 (login node): download data/weights/code → $HOME subdirs
  Phase 2 (compute node via SLURM): bind $HOME paths, execute — no network calls

  Compute nodes have zero internet access. Download everything beforehand.

--------------------------------------------------------------------------------
JUPYTERLAB SSH TUNNEL
--------------------------------------------------------------------------------
  1. Submit job on cluster:
       apptainer exec --nv --bind $HOME/code:/code <container>.sif jupyter --port 8888

  2. From local machine:
       ssh -L 8888:localhost:8888 -N user@login.cdac.in

  3. Open browser: http://localhost:8888

--------------------------------------------------------------------------------
USER VENV WORKFLOW
--------------------------------------------------------------------------------
  apptainer exec <container>.sif bash
  python3.11 -m venv --system-site-packages $HOME/envs/myenv
  source $HOME/envs/myenv/bin/activate
  unset PIP_CONSTRAINT    # required — releases base env lock
  pip install <extra-packages>

  venvs live in $HOME/envs (home-backed), survive container updates.

--------------------------------------------------------------------------------
CUDA DRIVER COMPATIBILITY
--------------------------------------------------------------------------------
  Container CUDA   Min host driver   Tested range
  12.4.1           525.60            525.60+
  Check: nvidia-smi

--------------------------------------------------------------------------------
CPU FALLBACK
--------------------------------------------------------------------------------
  Run without --nv / --gres=gpu. Warning printed: "No GPU detected — CPU mode".
  JAX will use CPU backend automatically when no GPU is visible.
  Test: CUDA_VISIBLE_DEVICES="" apptainer exec <container>.sif info

--------------------------------------------------------------------------------
INSTALLED PACKAGES
--------------------------------------------------------------------------------
  JAX              0.5.3
  jaxlib           0.5.3
  Flax             0.10.5
  Optax            0.2.4
  ml-dtypes        0.4.0
  NumPy            1.26.4
  Pandas           2.2.2
  Matplotlib       3.9.0
  Pillow           10.3.0
  SciPy            1.13.0
  JupyterLab       4.2.1
================================================================================
